{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Finance: Package report (ready.zip)",
      "type": "shell",
      "command": "./Reports/Finance/scripts/package-report.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Portfolio: Scaffold new report module",
      "type": "shell",
      "command": "./scripts/create-report-module.sh ${input:moduleName} '${input:reportTitle}'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "moduleName",
      "type": "promptString",
      "description": "Module folder name (e.g. HR)"
    },
    {
      "id": "reportTitle",
      "type": "promptString",
      "description": "Human-readable title (e.g. HR Reporting)"
    }
  ]
}
