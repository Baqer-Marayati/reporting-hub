	partition Fact_BalanceSheet = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""RefDate"" AS ""PostingDate"",#(lf)    YEAR(T0.""RefDate"") AS ""Year"",#(lf)    MONTH(T0.""RefDate"") AS ""MonthNo"",#(lf)    TO_VARCHAR(T0.""RefDate"", 'YYYY-MM') AS ""YearMonth"",#(lf)    T1.""Account"" AS ""AcctCode"",#(lf)    T2.""AcctName"" AS ""AcctName"",#(lf)    T2.""GroupMask"" AS ""GroupMask"",#(lf)    CASE#(lf)        WHEN T2.""GroupMask"" = 1 THEN 'Assets'#(lf)        WHEN T2.""GroupMask"" = 2 THEN 'Liabilities'#(lf)        WHEN T2.""GroupMask"" = 3 THEN 'Equity'#(lf)        ELSE 'Other'#(lf)    END AS ""BSSection"",#(lf)    COALESCE(T1.""Debit"", 0) - COALESCE(T1.""Credit"", 0) AS ""Amount"",#(lf)    UPPER(TRIM(T1.""ProfitCode"")) AS ""BranchCode"",#(lf)    B1.""PrcName"" AS ""BranchName"",#(lf)    UPPER(TRIM(T1.""OcrCode2"")) AS ""SalesTypeCode"",#(lf)    B2.""PrcName"" AS ""SalesTypeName"",#(lf)    UPPER(TRIM(T1.""OcrCode3"")) AS ""DepartmentCode"",#(lf)    B3.""PrcName"" AS ""DepartmentName""#(lf)FROM ""CANON"".""OJDT"" T0#(lf)INNER JOIN ""CANON"".""JDT1"" T1#(lf)    ON T0.""TransId"" = T1.""TransId""#(lf)INNER JOIN ""CANON"".""OACT"" T2#(lf)    ON T1.""Account"" = T2.""AcctCode""#(lf)LEFT JOIN ""CANON"".""OPRC"" B1#(lf)    ON T1.""ProfitCode"" = B1.""PrcCode"" AND B1.""DimCode"" = 1#(lf)LEFT JOIN ""CANON"".""OPRC"" B2#(lf)    ON T1.""OcrCode2"" = B2.""PrcCode"" AND B2.""DimCode"" = 2#(lf)LEFT JOIN ""CANON"".""OPRC"" B3#(lf)    ON T1.""OcrCode3"" = B3.""PrcCode"" AND B3.""DimCode"" = 3#(lf)WHERE T2.""GroupMask"" IN (1, 2, 3);")
				in
				    Source

	annotation PBI_ResultType = Table

