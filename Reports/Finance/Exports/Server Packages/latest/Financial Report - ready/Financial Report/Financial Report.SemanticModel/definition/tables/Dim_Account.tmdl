	partition Dim_Account = calculated
		mode: import
		source =
				
				FILTER (
				    DISTINCT (
				        SELECTCOLUMNS (
				            'Fact_PNL',
				            "AcctCode", 'Fact_PNL'[AcctCode],
				            "AcctName", 'Fact_PNL'[AcctName],
				            "PnLSection", 'Fact_PNL'[PnLSection],
				            "PnLOrder", 'Fact_PNL'[PnLOrder]
				        )
				    ),
				    NOT ISBLANK ( [AcctCode] )
