table Dim_Department
	lineageTag: 6f15b4b8-41bf-4f38-8678-d0da38c095af

	column DepartmentCode
		lineageTag: 6cdae773-2eff-4bf2-b783-43dbcb69c0a8
		summarizeBy: none
		isNameInferred
		sourceColumn: [DepartmentCode]

		annotation SummarizationSetBy = Automatic

	column DepartmentName
		lineageTag: ee9f435b-ea3e-4b2b-afe3-f57be7219566
		summarizeBy: none
		isNameInferred
		sourceColumn: [DepartmentName]

		annotation SummarizationSetBy = Automatic

	partition Dim_Department = calculated
		mode: import
		source =
				
				VAR BaseRows =
				    FILTER (
				        UNION (
				            SELECTCOLUMNS ( 'Fact_PNL', "DepartmentCode", 'Fact_PNL'[DepartmentCode], "DepartmentName", 'Fact_PNL'[DepartmentName] ),
				            SELECTCOLUMNS ( 'Fact_BalanceSheet', "DepartmentCode", 'Fact_BalanceSheet'[DepartmentCode], "DepartmentName", 'Fact_BalanceSheet'[DepartmentName] ),
				            SELECTCOLUMNS ( 'Fact_SalesDetail', "DepartmentCode", 'Fact_SalesDetail'[DepartmentCode], "DepartmentName", 'Fact_SalesDetail'[DepartmentName] )
				        ),
				        NOT ISBLANK ( [DepartmentCode] ) && TRIM ( [DepartmentCode] ) <> ""
				    )
				VAR DepartmentCodes =
				    SUMMARIZE ( BaseRows, [DepartmentCode] )
				RETURN
				    ADDCOLUMNS (
				        DepartmentCodes,
				        "DepartmentName",
				            VAR Code = [DepartmentCode]
				            RETURN
				                COALESCE (
				                    MAXX (
				                        FILTER ( BaseRows, [DepartmentCode] = Code && NOT ISBLANK ( [DepartmentName] ) && TRIM ( [DepartmentName] ) <> "" ),
				                        [DepartmentName]
				                    ),
				                    Code
				                )
				    )

	annotation PBI_Id = fca4c6fdc8f04085a7c9ae11e08c12f5

