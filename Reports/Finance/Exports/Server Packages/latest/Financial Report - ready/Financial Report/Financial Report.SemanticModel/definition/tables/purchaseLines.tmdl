table purchaseLines
	lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0801

	measure CommittedPO =
			
			CALCULATE ( SUM ( 'purchaseLines'[amountIncludingVAT] ), 'purchaseLines'[DocumentType] = "Order" )
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0802

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure UnCommittedPO =
			
			CALCULATE ( SUM ( 'purchaseLines'[amountIncludingVAT] ), 'purchaseLines'[DocumentType] = "Quote" )
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0803

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure UnCommittedPO1 = [UnCommittedPO]
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0804

		annotation PBI_FormatHint = {"isGeneralNumber":true}

