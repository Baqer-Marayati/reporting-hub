	partition purchaseLines = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""DocDate"" AS ""date"",#(lf)    T0.""DocNum"" AS ""documentNo"",#(lf)    'Quote' AS ""DocumentType"",#(lf)    T0.""CardName"" AS ""buyFromVendorName"",#(lf)    COALESCE(T1.""AcctCode"", T1.""ItemCode"", '') AS ""no"",#(lf)    COALESCE(T1.""LineTotal"", 0) AS ""amountIncludingVAT"",#(lf)    T1.""OcrCode"" AS ""shortcutDimension1Code"",#(lf)    T1.""OcrCode2"" AS ""shortcutDimension2Code""#(lf)FROM ""CANON"".""OPQT"" T0#(lf)INNER JOIN ""CANON"".""PQT1"" T1#(lf)    ON T0.""DocEntry"" = T1.""DocEntry""#(lf)WHERE T1.""LineStatus"" = 'O'#(lf)UNION ALL#(lf)SELECT#(lf)    T0.""DocDate"" AS ""date"",#(lf)    T0.""DocNum"" AS ""documentNo"",#(lf)    'Order' AS ""DocumentType"",#(lf)    T0.""CardName"" AS ""buyFromVendorName"",#(lf)    COALESCE(T1.""AcctCode"", T1.""ItemCode"", '') AS ""no"",#(lf)    COALESCE(T1.""LineTotal"", 0) AS ""amountIncludingVAT"",#(lf)    T1.""OcrCode"" AS ""shortcutDimension1Code"",#(lf)    T1.""OcrCode2"" AS ""shortcutDimension2Code""#(lf)FROM ""CANON"".""OPOR"" T0#(lf)INNER JOIN ""CANON"".""POR1"" T1#(lf)    ON T0.""DocEntry"" = T1.""DocEntry""#(lf)WHERE T1.""LineStatus"" = 'O';")
				in
				    Source

	annotation PBI_ResultType = Table

