	measure 'Overview KPI Value' =
			
			VAR KPIName = SELECTEDVALUE ( 'Dim_KPIRows'[KPI Label] )
			RETURN
			    SWITCH (
			        KPIName,
			        "Net Revenue", [Net Revenue],
			        "Gross Profit", [Gross Profit],
			        "Gross Margin %", [Gross Margin %],
			        "Operating Profit", [Operating Profit],
			        "Net Profit", [Net Profit],
			        "Net Margin %", [Net Margin %]
			    )
		lineageTag: 3ef3d741-8c6b-4aef-a2a2-9c21bf6d6777

	measure 'Statement Actual' =
			
			VAR RowType = SELECTEDVALUE ( 'Dim_ReportRows'[RowType] )
			VAR SectionName = SELECTEDVALUE ( 'Dim_ReportRows'[SectionName] )
			VAR AcctCode = SELECTEDVALUE ( 'Dim_ReportRows'[AcctCode] )
			VAR AccountValue =
			    CALCULATE ( [Amount Display], TREATAS ( { AcctCode }, 'Fact_PNL'[AcctCode] ) )
			RETURN
			    SWITCH (
			        TRUE (),
			        RowType = "Header", BLANK (),
			        RowType = "Account", AccountValue,
			        SectionName = "Gross Revenue", [Gross Revenue],
			        SectionName = "Revenue Adjustments", [Revenue Adjustments],
			        SectionName = "Net Revenue", [Net Revenue],
			        SectionName = "COGS", [COGS],
			        SectionName = "Gross Profit", [Gross Profit],
			        SectionName = "Operating Expenses", [Operating Expenses],
			        SectionName = "Operating Profit", [Operating Profit],
			        SectionName = "Other Income / Expense", [Other Income / Expense],
			        SectionName = "Tax & Extraordinary", [Tax & Extraordinary],
			        SectionName = "Net Profit", [Net Profit]
			    )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 0323ee9f-1b04-4d84-a00a-cf575bd48078

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

