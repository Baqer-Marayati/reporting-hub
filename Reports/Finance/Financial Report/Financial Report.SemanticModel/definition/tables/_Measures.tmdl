table _Measures
	lineageTag: 0b003672-c6f8-4fc5-babb-905868b460a7

	measure 'Amount Display' =
			
			VAR AmountValue = SUM ( 'Fact_PNL'[Amount] ) * -1
			RETURN
			    IF ( ABS ( AmountValue ) < 0.5, BLANK (), AmountValue )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: a0ccf380-721e-4d36-9948-997e3ffa8ddb

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Gross Revenue' =
			
			CALCULATE (
			    [Amount Display],
			    KEEPFILTERS ( 'Fact_PNL'[PnLSection] = "Revenue" )
			)
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 7b45f65f-dbc8-40a6-b5d8-0b9344f7c1b2

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Revenue Adjustments' =
			
			CALCULATE (
			    [Amount Display],
			    KEEPFILTERS ( 'Fact_PNL'[PnLSection] = "Revenue Contra" )
			)
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 011f9499-f6b4-455a-aa2a-7ec3e4504988

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Net Revenue' =
			
			[Gross Revenue] + [Revenue Adjustments]
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: b7e9729c-a247-4c5c-b737-cb6750f1eca0

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure COGS =
			
