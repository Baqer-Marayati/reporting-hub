	measure 'Total Cash Balance' =
			
			[Cash on Hand Balance] + [Cash in Bank Balance] + [Cash in POS Balance]
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: c1a2b3d4-e5f6-7890-a1b2-c3d4e5f60010

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Collection Rate %' =
			
			DIVIDE ( [Total Collections], [Total Collections] + [Total AR Outstanding], 0 )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c1a2b3d4-e5f6-7890-a1b2-c3d4e5f60011

	measure 'Avg AR per Customer' =
			
			DIVIDE ( [Total AR Outstanding], [AR Customer Count], 0 )
