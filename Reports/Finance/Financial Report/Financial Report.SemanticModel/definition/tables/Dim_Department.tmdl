table Dim_Department
	lineageTag: 6f15b4b8-41bf-4f38-8678-d0da38c095af

	column DepartmentCode
		lineageTag: 6cdae773-2eff-4bf2-b783-43dbcb69c0a8
		summarizeBy: none
		isNameInferred
		sourceColumn: [DepartmentCode]

		annotation SummarizationSetBy = Automatic

	column DepartmentName
		lineageTag: ee9f435b-ea3e-4b2b-afe3-f57be7219566
		summarizeBy: none
		isNameInferred
		sourceColumn: [DepartmentName]

		annotation SummarizationSetBy = Automatic

	partition Dim_Department = calculated
		mode: import
		source =
				
				VAR AllRows =
				    UNION (
				        SELECTCOLUMNS ( 'Fact_PNL', "Code", 'Fact_PNL'[DepartmentCode], "Name", 'Fact_PNL'[DepartmentName] ),
				        SELECTCOLUMNS ( 'Fact_BalanceSheet', "Code", 'Fact_BalanceSheet'[DepartmentCode], "Name", 'Fact_BalanceSheet'[DepartmentName] ),
				        SELECTCOLUMNS ( 'Fact_SalesDetail', "Code", 'Fact_SalesDetail'[DepartmentCode], "Name", 'Fact_SalesDetail'[DepartmentName] )
				    )
				VAR CleanRows =
				    FILTER ( AllRows, NOT ISBLANK ( [Code] ) && [Code] <> "" )
				RETURN
				    SELECTCOLUMNS (
				        ADDCOLUMNS (
				            SUMMARIZE ( CleanRows, [Code] ),
				            "ResolvedName",
				                VAR k = [Code]
				                VAR n =
				                    CALCULATE (
				                        MINX (
				                            FILTER ( CleanRows, [Code] = k && NOT ISBLANK ( [Name] ) && [Name] <> "" ),
				                            [Name]
				                        )
				                    )
				                RETURN COALESCE ( n, k )
				        ),
				        "DepartmentCode", [Code],
				        "DepartmentName", [ResolvedName]
				    )

	annotation PBI_Id = fca4c6fdc8f04085a7c9ae11e08c12f5

