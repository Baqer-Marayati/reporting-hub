table Dim_SalesType
	lineageTag: 1bdfbc95-2ca7-4fc1-9fc7-244676abf53f

	column SalesTypeCode
		lineageTag: 6c90c2b9-cfd0-4ef6-8e32-927bd0b09db1
		summarizeBy: none
		isNameInferred
		sourceColumn: [SalesTypeCode]

		annotation SummarizationSetBy = Automatic

	column SalesTypeName
		lineageTag: 70aa5f96-c59f-43aa-90d8-1ce6d7d8f3a2
		summarizeBy: none
		isNameInferred
		sourceColumn: [SalesTypeName]

		annotation SummarizationSetBy = Automatic

	partition Dim_SalesType = calculated
		mode: import
		source =
				
				VAR AllRows =
				    UNION (
				        SELECTCOLUMNS ( 'Fact_PNL', "Code", 'Fact_PNL'[SalesTypeCode], "Name", 'Fact_PNL'[SalesTypeName] ),
				        SELECTCOLUMNS ( 'Fact_BalanceSheet', "Code", 'Fact_BalanceSheet'[SalesTypeCode], "Name", 'Fact_BalanceSheet'[SalesTypeName] ),
				        SELECTCOLUMNS ( 'Fact_SalesDetail', "Code", 'Fact_SalesDetail'[SalesTypeCode], "Name", 'Fact_SalesDetail'[SalesTypeName] )
				    )
				VAR CleanRows =
				    FILTER ( AllRows, NOT ISBLANK ( [Code] ) && [Code] <> "" )
				RETURN
				    SELECTCOLUMNS (
				        ADDCOLUMNS (
				            SUMMARIZE ( CleanRows, [Code] ),
				            "ResolvedName",
				                VAR k = [Code]
				                VAR n =
				                    CALCULATE (
				                        MINX (
				                            FILTER ( CleanRows, [Code] = k && NOT ISBLANK ( [Name] ) && [Name] <> "" ),
				                            [Name]
				                        )
				                    )
				                RETURN COALESCE ( n, k )
				        ),
				        "SalesTypeCode", [Code],
				        "SalesTypeName", [ResolvedName]
				    )

	annotation PBI_Id = 49b2783602d0483f8324399df5aafda7

