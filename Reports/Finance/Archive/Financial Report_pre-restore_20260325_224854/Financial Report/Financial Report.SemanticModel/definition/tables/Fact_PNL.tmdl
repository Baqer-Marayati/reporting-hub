	partition Fact_PNL = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""RefDate"" AS ""PostingDate"",#(lf)    YEAR(T0.""RefDate"") AS ""Year"",#(lf)    MONTH(T0.""RefDate"") AS ""MonthNo"",#(lf)    TO_VARCHAR(T0.""RefDate"", 'YYYY-MM') AS ""YearMonth"",#(lf)    T1.""TransId"" AS ""TransId"",#(lf)    T1.""Line_ID"" AS ""LineId"",#(lf)    T1.""Account"" AS ""AcctCode"",#(lf)    T2.""AcctName"" AS ""AcctName"",#(lf)    COALESCE(T1.""Debit"", 0) AS ""Debit"",#(lf)    COALESCE(T1.""Credit"", 0) AS ""Credit"",#(lf)    COALESCE(T1.""Debit"", 0) - COALESCE(T1.""Credit"", 0) AS ""Amount"",#(lf)    UPPER(TRIM(T1.""ProfitCode"")) AS ""BranchCode"",#(lf)    B1.""PrcName"" AS ""BranchName"",#(lf)    UPPER(TRIM(T1.""OcrCode2"")) AS ""CostCenterCode"",#(lf)    B2.""PrcName"" AS ""CostCenterName"",#(lf)    UPPER(TRIM(T1.""OcrCode2"")) AS ""SalesTypeCode"",#(lf)    B2.""PrcName"" AS ""SalesTypeName"",#(lf)    UPPER(TRIM(T1.""OcrCode3"")) AS ""DepartmentCode"",#(lf)    B3.""PrcName"" AS ""DepartmentName"",#(lf)    CASE#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('41', '42', '43', '44', '45') THEN 'Revenue'#(lf)        WHEN LEFT(T1.""Account"", 2) = '46' THEN 'Revenue Contra'#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('51', '52', '53', '54', '55') THEN 'COGS'#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('61', '62', '63', '64', '65', '66') THEN 'Operating Expenses'#(lf)        WHEN LEFT(T1.""Account"", 2) = '71' THEN 'Other'#(lf)        WHEN LEFT(T1.""Account"", 2) = '81' THEN 'Tax'#(lf)        ELSE 'Unclassified'#(lf)    END AS ""PnLSection"",#(lf)    CASE#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('41', '42', '43', '44', '45') THEN 10#(lf)        WHEN LEFT(T1.""Account"", 2) = '46' THEN 15#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('51', '52', '53', '54', '55') THEN 20#(lf)        WHEN LEFT(T1.""Account"", 2) IN ('61', '62', '63', '64', '65', '66') THEN 40#(lf)        WHEN LEFT(T1.""Account"", 2) = '71' THEN 50#(lf)        WHEN LEFT(T1.""Account"", 2) = '81' THEN 60#(lf)        ELSE 90#(lf)    END AS ""PnLOrder""#(lf)FROM ""CANON"".""OJDT"" T0#(lf)INNER JOIN ""CANON"".""JDT1"" T1#(lf)    ON T0.""TransId"" = T1.""TransId""#(lf)INNER JOIN ""CANON"".""OACT"" T2#(lf)    ON T1.""Account"" = T2.""AcctCode""#(lf)LEFT JOIN ""CANON"".""OPRC"" B1#(lf)    ON T1.""ProfitCode"" = B1.""PrcCode"" AND B1.""DimCode"" = 1#(lf)LEFT JOIN ""CANON"".""OPRC"" B2#(lf)    ON T1.""OcrCode2"" = B2.""PrcCode"" AND B2.""DimCode"" = 2#(lf)LEFT JOIN ""CANON"".""OPRC"" B3#(lf)    ON T1.""OcrCode3"" = B3.""PrcCode"" AND B3.""DimCode"" = 3#(lf)WHERE T2.""GroupMask"" IN (4, 5, 6, 7, 8);")
				in
				    Source

	annotation PBI_ResultType = Table

