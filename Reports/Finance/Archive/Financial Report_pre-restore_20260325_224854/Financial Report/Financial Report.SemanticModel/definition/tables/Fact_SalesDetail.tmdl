	partition Fact_SalesDetail = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""DocDate"" AS ""PostingDate"",#(lf)    YEAR(T0.""DocDate"") AS ""Year"",#(lf)    MONTH(T0.""DocDate"") AS ""MonthNo"",#(lf)    TO_VARCHAR(T0.""DocDate"", 'YYYY-MM') AS ""YearMonth"",#(lf)    'Invoice' AS ""DocType"",#(lf)    T0.""DocNum"" AS ""DocNum"",#(lf)    T0.""CardCode"" AS ""CardCode"",#(lf)    T0.""CardName"" AS ""CardName"",#(lf)    T1.""ItemCode"" AS ""ItemCode"",#(lf)    T1.""Dscription"" AS ""ItemName"",#(lf)    T4.""ItmsGrpNam"" AS ""ItemGroupName"",#(lf)    COALESCE(NULLIF(TRIM(T3.""U_BusinessType""), ''), 'Unassigned') AS ""Item Business Type"",#(lf)    COALESCE(T1.""Quantity"", 0) AS ""Quantity"",#(lf)    COALESCE(T1.""LineTotal"", 0) AS ""NetSales"",#(lf)    COALESCE(T1.""GrssProfit"", 0) AS ""GrossProfit"",#(lf)    UPPER(TRIM(T1.""OcrCode"")) AS ""LocationCode"",#(lf)    D1.""PrcName"" AS ""LocationName"",#(lf)    UPPER(TRIM(T1.""OcrCode2"")) AS ""SalesTypeCode"",#(lf)    D2.""PrcName"" AS ""SalesTypeName"",#(lf)    UPPER(TRIM(T1.""OcrCode3"")) AS ""DepartmentCode"",#(lf)    D3.""PrcName"" AS ""DepartmentName""#(lf)FROM ""CANON"".""OINV"" T0#(lf)INNER JOIN ""CANON"".""INV1"" T1#(lf)    ON T0.""DocEntry"" = T1.""DocEntry""#(lf)LEFT JOIN ""CANON"".""OITM"" T3#(lf)    ON T1.""ItemCode"" = T3.""ItemCode""#(lf)LEFT JOIN ""CANON"".""OITB"" T4#(lf)    ON T3.""ItmsGrpCod"" = T4.""ItmsGrpCod""#(lf)LEFT JOIN ""CANON"".""OPRC"" D1#(lf)    ON T1.""OcrCode"" = D1.""PrcCode"" AND D1.""DimCode"" = 1#(lf)LEFT JOIN ""CANON"".""OPRC"" D2#(lf)    ON T1.""OcrCode2"" = D2.""PrcCode"" AND D2.""DimCode"" = 2#(lf)LEFT JOIN ""CANON"".""OPRC"" D3#(lf)    ON T1.""OcrCode3"" = D3.""PrcCode"" AND D3.""DimCode"" = 3#(lf)UNION ALL#(lf)SELECT#(lf)    T0.""DocDate"" AS ""PostingDate"",#(lf)    YEAR(T0.""DocDate"") AS ""Year"",#(lf)    MONTH(T0.""DocDate"") AS ""MonthNo"",#(lf)    TO_VARCHAR(T0.""DocDate"", 'YYYY-MM') AS ""YearMonth"",#(lf)    'Credit Memo' AS ""DocType"",#(lf)    T0.""DocNum"" AS ""DocNum"",#(lf)    T0.""CardCode"" AS ""CardCode"",#(lf)    T0.""CardName"" AS ""CardName"",#(lf)    T1.""ItemCode"" AS ""ItemCode"",#(lf)    T1.""Dscription"" AS ""ItemName"",#(lf)    T4.""ItmsGrpNam"" AS ""ItemGroupName"",#(lf)    COALESCE(NULLIF(TRIM(T3.""U_BusinessType""), ''), 'Unassigned') AS ""Item Business Type"",#(lf)    COALESCE(T1.""Quantity"", 0) * -1 AS ""Quantity"",#(lf)    COALESCE(T1.""LineTotal"", 0) * -1 AS ""NetSales"",#(lf)    COALESCE(T1.""GrssProfit"", 0) * -1 AS ""GrossProfit"",#(lf)    UPPER(TRIM(T1.""OcrCode"")) AS ""LocationCode"",#(lf)    D1.""PrcName"" AS ""LocationName"",#(lf)    UPPER(TRIM(T1.""OcrCode2"")) AS ""SalesTypeCode"",#(lf)    D2.""PrcName"" AS ""SalesTypeName"",#(lf)    UPPER(TRIM(T1.""OcrCode3"")) AS ""DepartmentCode"",#(lf)    D3.""PrcName"" AS ""DepartmentName""#(lf)FROM ""CANON"".""ORIN"" T0#(lf)INNER JOIN ""CANON"".""RIN1"" T1#(lf)    ON T0.""DocEntry"" = T1.""DocEntry""#(lf)LEFT JOIN ""CANON"".""OITM"" T3#(lf)    ON T1.""ItemCode"" = T3.""ItemCode""#(lf)LEFT JOIN ""CANON"".""OITB"" T4#(lf)    ON T3.""ItmsGrpCod"" = T4.""ItmsGrpCod""#(lf)LEFT JOIN ""CANON"".""OPRC"" D1#(lf)    ON T1.""OcrCode"" = D1.""PrcCode"" AND D1.""DimCode"" = 1#(lf)LEFT JOIN ""CANON"".""OPRC"" D2#(lf)    ON T1.""OcrCode2"" = D2.""PrcCode"" AND D2.""DimCode"" = 2#(lf)LEFT JOIN ""CANON"".""OPRC"" D3#(lf)    ON T1.""OcrCode3"" = D3.""PrcCode"" AND D3.""DimCode"" = 3;")
				in
				    Source

	annotation PBI_ResultType = Table

