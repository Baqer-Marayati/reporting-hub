	measure 'Net Revenue LY' =
			
			CALCULATE ( [Net Revenue], DATEADD ( 'Dim_Date'[Date], -1, YEAR ) )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: d27b1d3b-a0d2-4826-b58c-088a4cb4a607

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Net Revenue YTD' =
			
			VAR LastFactDate =
			    CALCULATE ( MAX ( 'Fact_PNL'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) )
			VAR MaxVisibleDate = MAX ( 'Dim_Date'[Date] )
			VAR EffectiveMaxDate =
			    IF ( ISBLANK ( LastFactDate ), BLANK (), MIN ( MaxVisibleDate, DATEVALUE ( LastFactDate ) ) )
			RETURN
			    IF (
			        ISBLANK ( EffectiveMaxDate ),
			        BLANK (),
			        CALCULATE (
			            [Net Revenue],
			            DATESBETWEEN (
			                'Dim_Date'[Date],
			                DATE ( YEAR ( EffectiveMaxDate ), 1, 1 ),
			                EffectiveMaxDate
			            )
			        )
			    )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 40f04f1a-fccb-4d24-a07d-b781a15a85f5

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

