	measure 'Selected Period Label' =
			
			VAR VisibleMinDate = MIN ( 'Dim_Date'[Date] )
			VAR VisibleMaxDate = MAX ( 'Dim_Date'[Date] )
			VAR LastFactDate =
			    MAXX (
			        {
			            DATEVALUE ( CALCULATE ( MAX ( 'Fact_PNL'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) ),
			            DATEVALUE ( CALCULATE ( MAX ( 'Fact_BalanceSheet'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) ),
			            DATEVALUE ( CALCULATE ( MAX ( 'Fact_SalesDetail'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) )
			        },
			        [Value]
			    )
			VAR FirstFactDate =
			    MINX (
			        {
			            DATEVALUE ( CALCULATE ( MIN ( 'Fact_PNL'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) ),
			            DATEVALUE ( CALCULATE ( MIN ( 'Fact_BalanceSheet'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) ),
			            DATEVALUE ( CALCULATE ( MIN ( 'Fact_SalesDetail'[PostingDate] ), REMOVEFILTERS ( 'Dim_Date' ) ) )
			        },
			        [Value]
			    )
			VAR MaxDate = IF ( ISBLANK ( LastFactDate ), BLANK (), MIN ( VisibleMaxDate, LastFactDate ) )
			VAR MinDate = IF ( ISBLANK ( FirstFactDate ), BLANK (), MAX ( VisibleMinDate, FirstFactDate ) )
			RETURN
			    IF (
			        ISBLANK ( MinDate ) || ISBLANK ( MaxDate ) || MinDate > MaxDate,
			        BLANK (),
			        FORMAT ( MinDate, "MMM YYYY" ) & " - " & FORMAT ( MaxDate, "MMM YYYY" )
			    )
		lineageTag: 91f014e9-5d09-4ddf-9def-fb5358edee1a

	measure 'Chart Row Actual' =
			
			VAR RowLabel =
			    COALESCE (
			        SELECTEDVALUE ( 'Dim_StatementSummaryRows'[RowLabel] ),
			        SELECTEDVALUE ( 'Dim_ChartRows'[RowLabel] )
			    )
			VAR Prefix =
			    COALESCE (
			        SELECTEDVALUE ( 'Dim_StatementSummaryRows'[CodePrefix] ),
			        SELECTEDVALUE ( 'Dim_ChartRows'[CodePrefix] )
			    )
			VAR PrefixLength =
			    COALESCE (
			        SELECTEDVALUE ( 'Dim_StatementSummaryRows'[CodeLength] ),
			        SELECTEDVALUE ( 'Dim_ChartRows'[CodeLength] )
			    )
			RETURN
			    SWITCH (
			        TRUE (),
			        RowLabel = "Turnover" || RowLabel = "Total Turnover", [Gross Revenue],
			        RowLabel = "Net Revenue", [Net Revenue],
			        RowLabel = "Gross Profit", [Gross Profit],
			        RowLabel = "Operating Profit", [Operating Profit],
			        RowLabel = "Net Profit", [Net Profit],
			        CONTAINSSTRING ( LOWER ( RowLabel ), "profit period" ), [Net Profit],
			        NOT ISBLANK ( Prefix ),
			            CALCULATE (
			                [Amount Display],
			                FILTER ( ALL ( 'Fact_PNL'[AcctCode] ), LEFT ( 'Fact_PNL'[AcctCode], PrefixLength ) = Prefix )
			            )
			    )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 98b1d51a-62e5-476e-aefb-f84b335c7486

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

