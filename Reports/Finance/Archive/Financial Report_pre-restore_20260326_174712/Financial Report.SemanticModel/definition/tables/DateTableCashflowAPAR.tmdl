table DateTableCashflowAPAR
	lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a1121

	column Date
		lineageTag: d1671705-55c8-4555-9c97-c1ae95c0f7f3
		isNameInferred
		sourceColumn: [Date]

	column 'Month Year'
		lineageTag: 89f05717-e221-487b-807d-01be001b8cec
		isNameInferred
		sourceColumn: [Month Year]

	column IsInLast6Months_PTO
		lineageTag: 7a381a39-cf6f-4999-8f52-b873aa3d5c92
		isNameInferred
		sourceColumn: [IsInLast6Months_PTO]

	partition DateTableCashflowAPAR = calculated
		mode: import
		source =
				
				SELECTCOLUMNS (
				    FILTER (
				        'DateTable',
				        'DateTable'[Date] >= DATE ( YEAR ( EDATE ( TODAY (), -5 ) ), MONTH ( EDATE ( TODAY (), -5 ) ), 1 )
				            && 'DateTable'[Date] <= EOMONTH ( TODAY (), 0 )
				    ),
				    "Date", 'DateTable'[Date],
				    "Month Year", 'DateTable'[Month Name Short],
				    "IsInLast6Months_PTO", TRUE ()
				)

	annotation PBI_Id = 4f1c4f8e3cc34d189a8c3f2e189a1121

