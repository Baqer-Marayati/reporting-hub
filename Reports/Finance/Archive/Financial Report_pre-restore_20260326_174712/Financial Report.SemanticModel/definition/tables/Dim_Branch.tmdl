table Dim_Branch
	lineageTag: 795d7bff-82fc-494b-8606-8b04a1c57fd1

	column BranchCode
		lineageTag: 8a5d3dc9-492e-4b5d-8774-c963e79ef622
		summarizeBy: none
		isNameInferred
		sourceColumn: [BranchCode]

		annotation SummarizationSetBy = Automatic

	column BranchName
		lineageTag: e089c29e-f165-463b-bb20-a4f6e6f5994f
		summarizeBy: none
		isNameInferred
		sourceColumn: [BranchName]

		annotation SummarizationSetBy = Automatic

	partition Dim_Branch = calculated
		mode: import
		source =
				
				VAR AllRows =
				    UNION (
				        SELECTCOLUMNS ( 'Fact_PNL', "Code", 'Fact_PNL'[BranchCode], "Name", 'Fact_PNL'[BranchName] ),
				        SELECTCOLUMNS ( 'Fact_BalanceSheet', "Code", 'Fact_BalanceSheet'[BranchCode], "Name", 'Fact_BalanceSheet'[BranchName] ),
				        SELECTCOLUMNS ( 'Fact_SalesDetail', "Code", 'Fact_SalesDetail'[LocationCode], "Name", 'Fact_SalesDetail'[LocationName] )
				    )
				VAR CleanRows =
				    FILTER ( AllRows, NOT ISBLANK ( [Code] ) && [Code] <> "" )
				RETURN
				    SELECTCOLUMNS (
				        ADDCOLUMNS (
				            SUMMARIZE ( CleanRows, [Code] ),
				            "ResolvedName",
				                VAR k = [Code]
				                VAR n =
				                    CALCULATE (
				                        MINX (
				                            FILTER ( CleanRows, [Code] = k && NOT ISBLANK ( [Name] ) && [Name] <> "" ),
				                            [Name]
				                        )
				                    )
				                RETURN COALESCE ( n, k )
				        ),
				        "BranchCode", [Code],
				        "BranchName", [ResolvedName]
				    )

	annotation PBI_Id = a724b8f0866c4f548322fdc3f8449e5c

