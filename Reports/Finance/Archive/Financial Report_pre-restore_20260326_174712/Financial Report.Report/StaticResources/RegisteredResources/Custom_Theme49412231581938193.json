{
  "$schema": "https://raw.githubusercontent.com/microsoft/powerbi-desktop-samples/refs/heads/main/Report%20Theme%20JSON%20Schema/reportThemeSchema-2.139.json",
  "name": "Finance - corporate blue",
  "background": "#FFFFFF",
  "backgroundLight": "#F8FBFF",
  "backgroundNeutral": "#F8FBFF",
  "foreground": "#1F2937",
  "foregroundNeutralSecondary": "#1F2937",
  "foregroundNeutralTertiary": "#475569",
  "center": "#1F2937",
  "good": "#15803D",
  "neutral": "#5B8DB8",
  "bad": "#B91C1C",
  "maximum": "#1F4E79",
  "minimum": "#9CC3E6",
  "hover": "#5B8DB8",
  "dataColors": [
    "#1F4E79",
    "#5B8DB8",
    "#9CC3E6",
    "#2C5282",
    "#3D6FA0",
    "#6B9AC4",
    "#A8C8E4",
    "#B8D8EF",
    "#D4E8F7",
    "#E8F2FA",
    "#4A6B8A",
    "#7AA3C9",
    "#C5DCF0",
    "#ADCCE6",
    "#153A5C",
    "#8EB4D4"
  ],
  "textClasses": {
    "callout": {
      "color": "#1F2937",
      "fontFace": "Segoe UI",
      "fontSize": 10.5
    },
    "dataTitle": {
      "color": "#1F2937",
      "fontSize": 10.5
    },
    "label": {
      "color": "#1F2937",
      "fontFace": "Segoe UI",
      "fontSize": 9
    },
    "title": {
      "color": "#1F2937",
      "fontFace": "Segoe UI",
      "fontSize": 10.5
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "*": [
          {
            "customizeSpacing": true,
            "spaceBelowSubTitle": 4,
            "spaceBelowTitle": 4
          },
          {
            "bottom": 16,
            "left": 16,
            "right": 16,
            "top": 16
          }
        ],
        "background": [
          {
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "border": [
          {
            "color": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "radius": 4,
            "show": true
          }
        ],
        "categoryAxis": [
          {
            "fontFamily": "Segoe UI",
            "gridlineColor": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "gridlineShow": false,
            "gridlineStyle": "solid",
            "gridlineThickness": 1,
            "labelColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "showAxisTitle": false,
            "titleFontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "titleFontSize": 9
          }
        ],
        "divider": [
          {
            "color": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "ignorePadding": false,
            "show": false,
            "style": "dashed"
          }
        ],
        "dropShadow": [
          {
            "color": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "position": "Outer",
            "preset": "Bottom",
            "show": false
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 1.5
          }
        ],
        "plotArea": [
          {
            "transparency": 80
          }
        ],
        "subTitle": [
          {
            "fontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "fontFamily": "Segoe UI",
            "fontSize": 10.5,
            "titleWrap": true
          }
        ],
        "title": [
          {
            "bold": false,
            "fontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "titleWrap": true
          }
        ],
        "valueAxis": [
          {
            "fontFamily": "Segoe UI",
            "gridlineColor": {
              "solid": {
                "color": "#D9E2EC"
              }
            },
            "gridlineShow": true,
            "gridlineStyle": "solid",
            "gridlineThickness": 1,
            "labelColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "showAxisTitle": false,
            "titleFontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "titleFontSize": 9
          }
        ],
        "visualTooltip": [
          {
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "titleFontColor": {
              "solid": {
                "color": "#1F2937"
              }
            },
            "valueFontColor": {
              "solid": {
                "color": "#1F2937"
              }
            }
          }
        ]
      }
    }
  }
}
