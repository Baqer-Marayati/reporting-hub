	partition CollectionsFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    J.""ShortName""                                       AS ""CardCode"",#(lf)    C.""CardName""                                        AS ""CardName"",#(lf)    '' AS ""BPType"",#(lf)    NULLIF(#(lf)        TRIM(#(lf)            COALESCE(#(lf)                CASE#(lf)                    WHEN COALESCE(C.""QryGroup1"",'N') = 'Y' THEN 'Haleem'#(lf)                    ELSE ''#(lf)                END,#(lf)                ''#(lf)            )#(lf)            ||#(lf)            CASE#(lf)                WHEN COALESCE(C.""QryGroup1"",'N') = 'Y'#(lf)                 AND COALESCE(C.""QryGroup2"",'N') = 'Y'#(lf)                THEN ', '#(lf)                ELSE ''#(lf)            END#(lf)            ||#(lf)            COALESCE(#(lf)                CASE#(lf)                    WHEN COALESCE(C.""QryGroup2"",'N') = 'Y' THEN 'Saadallah'#(lf)                    ELSE ''#(lf)                END,#(lf)                ''#(lf)            )#(lf)        ),#(lf)        ''#(lf)    )                                                   AS ""CollectorName"",#(lf)    CAST(OJ.""RefDate"" AS DATE)                          AS ""PostingDate"",#(lf)    CAST(OJ.""TaxDate"" AS DATE)                          AS ""DocumentDate"",#(lf)    CAST(J.""DueDate"" AS DATE)                           AS ""DueDate"",#(lf)    OJ.""TransId""                                        AS ""TransId"",#(lf)    OJ.""TransType""                                      AS ""TransType"",#(lf)    OJ.""BaseRef""                                        AS ""OriginNo"",#(lf)    J.""ContraAct""                                       AS ""OffsetAccount"",#(lf)    COALESCE(OJ.""Memo"", J.""LineMemo"")                   AS ""Details"",#(lf)    J.""Account""                                         AS ""GLAccount"",#(lf)    CASE#(lf)        WHEN OJ.""TransType"" = 13  THEN 'IN'#(lf)        WHEN OJ.""TransType"" = 14  THEN 'CN'#(lf)        WHEN OJ.""TransType"" = 24  THEN 'RC'#(lf)        WHEN OJ.""TransType"" = 30  THEN 'JE'#(lf)        WHEN OJ.""TransType"" = 321 THEN 'JR'#(lf)        ELSE CAST(OJ.""TransType"" AS NVARCHAR(20))#(lf)    END                                                 AS ""Origin"",#(lf)    COALESCE(J.""Credit"", 0)                             AS ""CollectedAmount""#(lf)FROM ""PAPERENTITY"".""JDT1"" J#(lf)JOIN ""PAPERENTITY"".""OJDT"" OJ#(lf)    ON OJ.""TransId"" = J.""TransId""#(lf)JOIN ""PAPERENTITY"".""OCRD"" C#(lf)    ON C.""CardCode"" = J.""ShortName""#(lf)   AND C.""CardType"" = 'C'#(lf)WHERE#(lf)    COALESCE(J.""Credit"", 0) <> 0#(lf)    AND OJ.""RefDate"" >= ADD_DAYS(CURRENT_DATE, -365)#(lf)ORDER BY#(lf)    OJ.""RefDate"",#(lf)    OJ.""TransId"";")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

