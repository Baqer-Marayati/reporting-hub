	partition ReceivablesFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "WITH OpenBP AS (#(lf)    SELECT#(lf)        J.""ShortName""                                     AS ""CardCode"",#(lf)        C.""CardName""                                      AS ""CardName"",#(lf)        '' AS ""BPType"",#(lf)        NULLIF(#(lf)            TRIM(#(lf)                COALESCE(#(lf)                    CASE#(lf)                        WHEN COALESCE(C.""QryGroup1"",'N') = 'Y' THEN 'Haleem'#(lf)                        ELSE ''#(lf)                    END,#(lf)                    ''#(lf)                )#(lf)                ||#(lf)                CASE#(lf)                    WHEN COALESCE(C.""QryGroup1"",'N') = 'Y'#(lf)                     AND COALESCE(C.""QryGroup2"",'N') = 'Y'#(lf)                    THEN ', '#(lf)                    ELSE ''#(lf)                END#(lf)                ||#(lf)                COALESCE(#(lf)                    CASE#(lf)                        WHEN COALESCE(C.""QryGroup2"",'N') = 'Y' THEN 'Saadallah'#(lf)                        ELSE ''#(lf)                    END,#(lf)                    ''#(lf)                )#(lf)            ),#(lf)            ''#(lf)        )                                                  AS ""CollectorName"",#(lf)        OJ.""TransId""                                      AS ""TransId"",#(lf)        OJ.""TransType""                                    AS ""TransType"",#(lf)        OJ.""RefDate""                                      AS ""RefDate"",#(lf)        J.""DueDate""                                       AS ""DueDate"",#(lf)        OJ.""BaseRef""                                      AS ""BaseRef"",#(lf)        COALESCE(OJ.""Memo"", J.""LineMemo"")                 AS ""Memo"",#(lf)        (COALESCE(J.""BalDueDeb"",0) - COALESCE(J.""BalDueCred"",0)) AS ""OpenAmount"",#(lf)        DAYS_BETWEEN(J.""DueDate"", CURRENT_DATE)           AS ""DaysPastDue""#(lf)    FROM ""PAPERENTITY"".""JDT1"" J#(lf)    JOIN ""PAPERENTITY"".""OJDT"" OJ#(lf)        ON OJ.""TransId"" = J.""TransId""#(lf)    JOIN ""PAPERENTITY"".""OCRD"" C#(lf)        ON C.""CardCode"" = J.""ShortName""#(lf)       AND C.""CardType"" = 'C'#(lf)    WHERE#(lf)        (COALESCE(J.""BalDueDeb"",0) <> 0 OR COALESCE(J.""BalDueCred"",0) <> 0)#(lf))#(lf)SELECT#(lf)    ""CardCode"",#(lf)    ""CardName"",#(lf)    ""BPType"",#(lf)    ""CollectorName"",#(lf)    ""TransId"",#(lf)    ""TransType"",#(lf)    ""RefDate"",#(lf)    ""DueDate"",#(lf)    ""BaseRef"",#(lf)    ""Memo"",#(lf)    ""OpenAmount"",#(lf)    ""DaysPastDue"",#(lf)    CASE WHEN ""DaysPastDue"" < 0 THEN ""OpenAmount"" ELSE 0 END AS ""FutureRemit"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 0  AND 30  THEN ""OpenAmount"" ELSE 0 END AS ""B0_30"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 31 AND 60  THEN ""OpenAmount"" ELSE 0 END AS ""B31_60"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 61 AND 90  THEN ""OpenAmount"" ELSE 0 END AS ""B61_90"",#(lf)    CASE WHEN ""DaysPastDue"" BETWEEN 91 AND 120 THEN ""OpenAmount"" ELSE 0 END AS ""B91_120"",#(lf)    CASE WHEN ""DaysPastDue"" >= 121            THEN ""OpenAmount"" ELSE 0 END AS ""B121Plus""#(lf)FROM OpenBP#(lf)WHERE ""OpenAmount"" <> 0;")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

