	partition CashPositionFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    A.""AcctCode""        AS ""AccountCode"",#(lf)    A.""AcctName""        AS ""AccountName"",#(lf)    CASE#(lf)        WHEN LOWER(A.""AcctName"") LIKE '%cash%' OR LOWER(A.""AcctName"") LIKE '%صندوق%' THEN 'Cash on Hand'#(lf)        WHEN LOWER(A.""AcctName"") LIKE '%bank%' OR LOWER(A.""AcctName"") LIKE '%مصرف%' OR LOWER(A.""AcctName"") LIKE '%بنك%' THEN 'Bank'#(lf)        WHEN LOWER(A.""AcctName"") LIKE '%pos%' OR LOWER(A.""AcctName"") LIKE '%نقطة بيع%' THEN 'POS'#(lf)        ELSE 'Other'#(lf)    END AS ""AccountType"",#(lf)    SUM(J.""Debit"")  AS ""TotalDebit"",#(lf)    SUM(J.""Credit"") AS ""TotalCredit"",#(lf)    SUM(J.""Debit"" - J.""Credit"") AS ""Balance""#(lf)FROM ""PAPERENTITY"".""OACT"" A#(lf)LEFT JOIN ""PAPERENTITY"".""JDT1"" J#(lf)    ON J.""Account"" = A.""AcctCode""#(lf)WHERE#(lf)    A.""GroupMask"" = 1#(lf)    AND A.""Postable"" = 'Y'#(lf)    AND (#(lf)        LOWER(A.""AcctName"") LIKE '%cash%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%bank%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%pos%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%صندوق%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%مصرف%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%بنك%'#(lf)        OR LOWER(A.""AcctName"") LIKE '%نقطة بيع%'#(lf)        OR A.""AcctCode"" LIKE '1101010101%'#(lf)        OR A.""AcctCode"" LIKE '1101010102%'#(lf)        OR A.""AcctCode"" LIKE '1101010103%'#(lf)    )#(lf)GROUP BY#(lf)    A.""AcctCode"",#(lf)    A.""AcctName""#(lf)ORDER BY#(lf)    A.""AcctCode"";")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

