table Dim_Warehouse
	lineageTag: 22222222-2222-2222-2222-222222222001

	column WhsCode
		dataType: string
		lineageTag: 22222222-2222-2222-2222-222222222002
		summarizeBy: none
		sourceColumn: WhsCode

		annotation SummarizationSetBy = Automatic

	column WhsName
		dataType: string
		lineageTag: 22222222-2222-2222-2222-222222222003
		summarizeBy: none
		sourceColumn: WhsName

		annotation SummarizationSetBy = Automatic

	column IsActive
		dataType: int64
		formatString: 0
		lineageTag: 22222222-2222-2222-2222-222222222004
		summarizeBy: none
		sourceColumn: IsActive

		annotation SummarizationSetBy = Automatic

	partition Dim_Warehouse = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""WhsCode"",#(lf)    T0.""WhsName"",#(lf)    CASE WHEN T0.""Inactive"" = 'Y' THEN 0 ELSE 1 END AS ""IsActive""#(lf)FROM ""CANON"".""OWHS"" T0#(lf)WHERE T0.""WhsName"" IN ('Dora', 'Erbil', 'Sadoon', 'Showroom Ilwea')")
				in
				    Source

	annotation PBI_ResultType = Table

