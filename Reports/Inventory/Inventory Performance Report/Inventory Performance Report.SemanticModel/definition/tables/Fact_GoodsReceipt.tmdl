	partition Fact_GoodsReceipt = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""DocEntry"",#(lf)    T0.""DocNum"",#(lf)    T0.""DocDate"",#(lf)    T0.""CardCode"",#(lf)    T0.""CardName"",#(lf)    T1.""ItemCode"",#(lf)    T1.""Dscription"" AS ""ItemDescription"",#(lf)    T1.""Quantity"",#(lf)    T1.""Price"",#(lf)    T1.""LineTotal"",#(lf)    T1.""WhsCode""#(lf)FROM ""CANON"".""OPDN"" T0#(lf)INNER JOIN ""CANON"".""PDN1"" T1 ON T0.""DocEntry"" = T1.""DocEntry""#(lf)WHERE T1.""ItemCode"" IS NOT NULL AND T1.""ItemCode"" <> ''#(lf)AND T0.""DocDate"" >= '2026-01-01'")
				in
				    Source

	annotation PBI_ResultType = Table

