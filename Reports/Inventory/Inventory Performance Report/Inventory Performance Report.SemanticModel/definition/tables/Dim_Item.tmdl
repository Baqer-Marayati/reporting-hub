	partition Dim_Item = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""ItemCode"",#(lf)    T0.""ItemName"",#(lf)    T0.""ItemType"",#(lf)    COALESCE(T1.""ItmsGrpNam"", 'Unassigned') AS ""ItemGroup"",#(lf)    COALESCE(T0.""U_BusinessType"", '') AS ""U_BusinessType"",#(lf)    COALESCE(T0.""U_GroupType"", '') AS ""U_GroupType"",#(lf)    COALESCE(T0.""U_ProductType"", '') AS ""U_ProductType"",#(lf)    COALESCE(T0.""U_SegmentType"", '') AS ""U_SegmentType"",#(lf)    COALESCE(T0.""InvntryUom"", '') AS ""UOM"",#(lf)    T0.""OnHand"",#(lf)    T0.""IsCommited"",#(lf)    T0.""OnOrder"",#(lf)    T0.""AvgPrice"",#(lf)    T0.""LastPurPrc"",#(lf)    T0.""LastPurDat"",#(lf)    CASE WHEN T0.""ManSerNum"" = 'Y' THEN 1 ELSE 0 END AS ""IsSerialTracked"",#(lf)    CASE WHEN T0.""validFor"" = 'Y' AND T0.""frozenFor"" = 'N' THEN 1 ELSE 0 END AS ""IsActive""#(lf)FROM ""CANON"".""OITM"" T0#(lf)LEFT JOIN ""CANON"".""OITB"" T1 ON T0.""ItmsGrpCod"" = T1.""ItmsGrpCod""#(lf)WHERE T0.""InvntItem"" = 'Y'")
				in
				    Source

	annotation PBI_ResultType = Table

