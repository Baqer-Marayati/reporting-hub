	partition Fact_Transfer = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""DocEntry"",#(lf)    T0.""DocNum"",#(lf)    T0.""DocDate"",#(lf)    T1.""ItemCode"",#(lf)    T1.""Dscription"" AS ""ItemDescription"",#(lf)    T1.""Quantity"",#(lf)    T1.""FromWhsCod"" AS ""FromWhsCode"",#(lf)    T1.""WhsCode"" AS ""ToWhsCode""#(lf)FROM ""CANON"".""OWTR"" T0#(lf)INNER JOIN ""CANON"".""WTR1"" T1 ON T0.""DocEntry"" = T1.""DocEntry""#(lf)INNER JOIN ""CANON"".""OWHS"" T2 ON T1.""WhsCode"" = T2.""WhsCode""#(lf)WHERE T2.""WhsName"" IN ('Dora', 'Erbil', 'Sadoon', 'Showroom Ilwea')#(lf)AND T0.""DocDate"" >= '2026-01-01'")
				in
				    Source

	annotation PBI_ResultType = Table

