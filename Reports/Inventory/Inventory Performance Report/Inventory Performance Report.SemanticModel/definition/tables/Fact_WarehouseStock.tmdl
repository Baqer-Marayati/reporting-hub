	partition Fact_WarehouseStock = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T0.""ItemCode"",#(lf)    T0.""WhsCode"",#(lf)    T0.""OnHand"",#(lf)    T0.""IsCommited"",#(lf)    T0.""OnOrder"",#(lf)    T0.""MinStock"",#(lf)    T0.""MaxStock""#(lf)FROM ""CANON"".""OITW"" T0#(lf)INNER JOIN ""CANON"".""OITM"" T1 ON T0.""ItemCode"" = T1.""ItemCode""#(lf)INNER JOIN ""CANON"".""OWHS"" T2 ON T0.""WhsCode"" = T2.""WhsCode""#(lf)WHERE T2.""WhsName"" IN ('Dora', 'Erbil', 'Sadoon', 'Showroom Ilwea')#(lf)AND (T0.""OnHand"" <> 0 OR T0.""IsCommited"" <> 0 OR T0.""OnOrder"" <> 0)")
				in
				    Source

	annotation PBI_ResultType = Table

