	partition InventoryValuation = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "SELECT#(lf)    T2.""WhsName"",#(lf)    T0.""WhsCode"",#(lf)    T1.""ItemCode"",#(lf)    T1.""ItemName"",#(lf)    T1.""U_BusinessType"",#(lf)    T1.""U_GroupType"",#(lf)    T1.""U_ProductType"",#(lf)    T1.""U_SegmentType"",#(lf)    SUM(T0.""OnHand"")      AS ""StockQty"",#(lf)    SUM(T0.""StockValue"")  AS ""StockValue""#(lf)FROM ""CANON"".""OITW"" T0#(lf)INNER JOIN ""CANON"".""OITM"" T1 ON T0.""ItemCode"" = T1.""ItemCode""#(lf)INNER JOIN ""CANON"".""OWHS"" T2 ON T0.""WhsCode"" = T2.""WhsCode""#(lf)WHERE T1.""InvntItem"" = 'Y'#(lf)AND T2.""WhsName"" IN ('Dora', 'Erbil', 'Sadoon', 'Showroom Ilwea')#(lf)GROUP BY#(lf)    T2.""WhsName"",#(lf)    T0.""WhsCode"",#(lf)    T1.""ItemCode"",#(lf)    T1.""ItemName"",#(lf)    T1.""U_BusinessType"",#(lf)    T1.""U_GroupType"",#(lf)    T1.""U_ProductType"",#(lf)    T1.""U_SegmentType""")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

