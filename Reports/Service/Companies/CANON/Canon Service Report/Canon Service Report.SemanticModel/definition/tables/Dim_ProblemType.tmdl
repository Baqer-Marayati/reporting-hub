table Dim_ProblemType
	lineageTag: d1a00007-0001-4000-a007-000000000001

	column ProblemTypeID
		dataType: int64
		formatString: 0
		lineageTag: d1a00007-0001-4000-a007-000000000002
		summarizeBy: none
		sourceColumn: ProblemTypeID

		annotation SummarizationSetBy = Automatic

	column ProblemTypeName
		dataType: string
