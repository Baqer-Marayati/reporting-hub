	partition DimBusinessPartner = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "/* ===========================================================#(lf)   DimBusinessPartner (Customers)#(lf)   - Includes 5 UDFs#(lf)   - Includes CollectorProperty from OPRT (PrtId)#(lf)   - Assumes exactly 1 Collector property per customer#(lf)   =========================================================== */#(lf)#(lf)WITH BP AS (#(lf)    SELECT#(lf)        C.""CardCode"",#(lf)        C.""CardName"",#(lf)        C.""U_PartnerType""   AS ""BPType"",#(lf)        C.""U_SectorType"",#(lf)        C.""U_SolutionType"",#(lf)        C.""U_IndustryType"",#(lf)        C.""U_ProductType"",#(lf)        C.""U_Class"",#(lf)#(lf)        /* Property flags */#(lf)        C.""QryGroup1"",  C.""QryGroup2"",  C.""QryGroup3"",  C.""QryGroup4"",  C.""QryGroup5"",#(lf)        C.""QryGroup6"",  C.""QryGroup7"",  C.""QryGroup8"",  C.""QryGroup9"",  C.""QryGroup10"",#(lf)        C.""QryGroup11"", C.""QryGroup12"", C.""QryGroup13"", C.""QryGroup14"", C.""QryGroup15"",#(lf)        C.""QryGroup16"", C.""QryGroup17"", C.""QryGroup18"", C.""QryGroup19"", C.""QryGroup20"",#(lf)        C.""QryGroup21"", C.""QryGroup22"", C.""QryGroup23""#(lf)#(lf)    FROM ""CANON"".""OCRD"" C#(lf)    WHERE C.""CardType"" = 'C'#(lf)),#(lf)#(lf)BPProps AS (#(lf)    SELECT ""CardCode"", 1  AS ""PrtId"" FROM BP WHERE ""QryGroup1""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 2  FROM BP WHERE ""QryGroup2""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 3  FROM BP WHERE ""QryGroup3""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 4  FROM BP WHERE ""QryGroup4""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 5  FROM BP WHERE ""QryGroup5""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 6  FROM BP WHERE ""QryGroup6""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 7  FROM BP WHERE ""QryGroup7""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 8  FROM BP WHERE ""QryGroup8""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 9  FROM BP WHERE ""QryGroup9""  = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 10 FROM BP WHERE ""QryGroup10"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 11 FROM BP WHERE ""QryGroup11"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 12 FROM BP WHERE ""QryGroup12"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 13 FROM BP WHERE ""QryGroup13"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 14 FROM BP WHERE ""QryGroup14"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 15 FROM BP WHERE ""QryGroup15"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 16 FROM BP WHERE ""QryGroup16"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 17 FROM BP WHERE ""QryGroup17"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 18 FROM BP WHERE ""QryGroup18"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 19 FROM BP WHERE ""QryGroup19"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 20 FROM BP WHERE ""QryGroup20"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 21 FROM BP WHERE ""QryGroup21"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 22 FROM BP WHERE ""QryGroup22"" = 'Y'#(lf)    UNION ALL SELECT ""CardCode"", 23 FROM BP WHERE ""QryGroup23"" = 'Y'#(lf)),#(lf)#(lf)Collector AS (#(lf)    SELECT#(lf)        X.""CardCode"",#(lf)        MAX(P.""Name"") AS ""CollectorProperty""#(lf)    FROM BPProps X#(lf)    JOIN ""CANON"".""OPRT"" P#(lf)        ON P.""PrtId"" = X.""PrtId""#(lf)    WHERE P.""Name"" LIKE 'Collector:%'#(lf)    GROUP BY X.""CardCode""#(lf))#(lf)#(lf)SELECT#(lf)    B.""CardCode"",#(lf)    B.""CardName"",#(lf)    B.""BPType"",#(lf)    B.""U_SectorType"",#(lf)    B.""U_SolutionType"",#(lf)    B.""U_IndustryType"",#(lf)    B.""U_ProductType"",#(lf)    COALESCE(B.""U_Class"", '-') AS ""BPClass"",#(lf)    COALESCE(C.""CollectorProperty"", '(No Collector)') AS ""CollectorProperty""#(lf)#(lf)FROM BP B#(lf)LEFT JOIN Collector C#(lf)    ON C.""CardCode"" = B.""CardCode"";")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

