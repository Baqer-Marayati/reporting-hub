	partition SalesFact = m
		mode: import
		source =
				let
				    Source = Odbc.Query("dsn=HANA_B1", "WITH InvTotals AS (#(lf)    SELECT ""DocEntry"", SUM(""LineTotal"") AS ""SumLineTotal""#(lf)    FROM ""CANON"".""INV1""#(lf)    GROUP BY ""DocEntry""#(lf)),#(lf)CrTotals AS (#(lf)    SELECT ""DocEntry"", SUM(""LineTotal"") AS ""SumLineTotal""#(lf)    FROM ""CANON"".""RIN1""#(lf)    GROUP BY ""DocEntry""#(lf)),#(lf)WarrantyAP AS (#(lf)    SELECT#(lf)        H.""DocDate""                              AS ""DocDate"",#(lf)        'Warranty'                               AS ""BPType"",#(lf)        'WARRANTY'                               AS ""CardCode"",#(lf)        'Warranty Provision'                     AS ""CardName"",#(lf)        -1                                       AS ""SlpCode"",#(lf)        'Warranty'                               AS ""SalesPerson"",#(lf)        'Warranty'                               AS ""SalesDept"",#(lf)        'Warranty'                               AS ""SalesType"",#(lf)        'Warranty'                               AS ""BusinessType"",#(lf)        'Warranty'                               AS ""U_GroupType"",#(lf)        'Warranty'                               AS ""U_ProductType"",#(lf)        'Warranty'                               AS ""U_SegmentType"",#(lf)        'SV003'                                  AS ""ItemCode"",#(lf)        'Warranty Provision'                     AS ""ItemName"",#(lf)        0                                        AS ""Qty"",#(lf)        0                                        AS ""Sales"",#(lf)        SUM(L.""LineTotal"")                       AS ""COGS""#(lf)    FROM ""CANON"".""OPCH"" H#(lf)    JOIN ""CANON"".""PCH1"" L ON L.""DocEntry"" = H.""DocEntry""#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)      AND L.""ItemCode"" = 'SV003'#(lf)    GROUP BY H.""DocDate""#(lf)),#(lf)WarrantyAPCredit AS (#(lf)    SELECT#(lf)        H.""DocDate""                              AS ""DocDate"",#(lf)        'Warranty'                               AS ""BPType"",#(lf)        'WARRANTY'                               AS ""CardCode"",#(lf)        'Warranty Provision'                     AS ""CardName"",#(lf)        -1                                       AS ""SlpCode"",#(lf)        'Warranty'                               AS ""SalesPerson"",#(lf)        'Warranty'                               AS ""SalesDept"",#(lf)        'Warranty'                               AS ""SalesType"",#(lf)        'Warranty'                               AS ""BusinessType"",#(lf)        'Warranty'                               AS ""U_GroupType"",#(lf)        'Warranty'                               AS ""U_ProductType"",#(lf)        'Warranty'                               AS ""U_SegmentType"",#(lf)        'SV003'                                  AS ""ItemCode"",#(lf)        'Warranty Provision'                     AS ""ItemName"",#(lf)        0                                        AS ""Qty"",#(lf)        0                                        AS ""Sales"",#(lf)        SUM(L.""LineTotal"") * -1                  AS ""COGS""#(lf)    FROM ""CANON"".""ORPC"" H#(lf)    JOIN ""CANON"".""RPC1"" L ON L.""DocEntry"" = H.""DocEntry""#(lf)    WHERE H.""CANCELED"" = 'N'#(lf)      AND L.""ItemCode"" = 'SV003'#(lf)    GROUP BY H.""DocDate""#(lf))#(lf)SELECT#(lf)    T0.""DocDate"" AS ""DocDate"",#(lf)    COALESCE(C.""U_PartnerType"", 'Unknown') AS ""BPType"",#(lf)    T0.""CardCode"" AS ""CardCode"",#(lf)    T0.""CardName"" AS ""CardName"",#(lf)    T0.""SlpCode"" AS ""SlpCode"",#(lf)    COALESCE(S.""SlpName"", 'Unassigned') AS ""SalesPerson"",#(lf)    COALESCE(S.""U_SalesDept"", 'Unassigned') AS ""SalesDept"",#(lf)    COALESCE(S.""U_SalesType"", 'Unassigned') AS ""SalesType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(NULLIF(TRIM(I.""U_BusinessType""), ''), 'Unassigned') END AS ""BusinessType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_GroupType"", 'Unassigned') END AS ""U_GroupType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_ProductType"", 'Unassigned') END AS ""U_ProductType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_SegmentType"", 'Unassigned') END AS ""U_SegmentType"",#(lf)    COALESCE(T1.""ItemCode"", '(No Item)') AS ""ItemCode"",#(lf)    COALESCE(I.""ItemName"", T1.""Dscription"", 'Unknown') AS ""ItemName"",#(lf)    COALESCE(T1.""Quantity"", 0) AS ""Qty"",#(lf)    COALESCE(T1.""LineTotal"", 0)#(lf)        + CASE#(lf)            WHEN TT.""SumLineTotal"" = 0 OR TT.""SumLineTotal"" IS NULL THEN 0#(lf)            ELSE (COALESCE(T1.""LineTotal"", 0) * COALESCE(T0.""DiscSum"", 0) * -1) / TT.""SumLineTotal""#(lf)          END AS ""Sales"",#(lf)    CASE#(lf)        WHEN T1.""ItemCode"" IS NULL THEN 0#(lf)        ELSE COALESCE(T1.""StockValue"", 0)#(lf)    END AS ""COGS""#(lf)FROM ""CANON"".""OINV"" T0#(lf)INNER JOIN ""CANON"".""INV1"" T1 ON T0.""DocEntry"" = T1.""DocEntry""#(lf)LEFT JOIN InvTotals TT ON TT.""DocEntry"" = T0.""DocEntry""#(lf)LEFT JOIN ""CANON"".""OCRD"" C ON C.""CardCode"" = T0.""CardCode""#(lf)LEFT JOIN ""CANON"".""OITM"" I ON I.""ItemCode"" = T1.""ItemCode""#(lf)LEFT JOIN ""CANON"".""OSLP"" S ON S.""SlpCode"" = T0.""SlpCode""#(lf)WHERE#(lf)    T1.""ItemCode"" IS NOT NULL#(lf)    OR (#(lf)        T1.""ItemCode"" IS NULL#(lf)        AND COALESCE(T1.""LineTotal"", 0) <> 0#(lf)        AND (T1.""AcctCode"" LIKE '45%' OR T1.""AcctCode"" LIKE '46%')#(lf)    )#(lf)UNION ALL#(lf)SELECT#(lf)    T0.""DocDate"" AS ""DocDate"",#(lf)    COALESCE(C.""U_PartnerType"", 'Unknown') AS ""BPType"",#(lf)    T0.""CardCode"" AS ""CardCode"",#(lf)    T0.""CardName"" AS ""CardName"",#(lf)    T0.""SlpCode"" AS ""SlpCode"",#(lf)    COALESCE(S.""SlpName"", 'Unassigned') AS ""SalesPerson"",#(lf)    COALESCE(S.""U_SalesDept"", 'Unassigned') AS ""SalesDept"",#(lf)    COALESCE(S.""U_SalesType"", 'Unassigned') AS ""SalesType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(NULLIF(TRIM(I.""U_BusinessType""), ''), 'Unassigned') END AS ""BusinessType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_GroupType"", 'Unassigned') END AS ""U_GroupType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_ProductType"", 'Unassigned') END AS ""U_ProductType"",#(lf)    CASE WHEN T1.""ItemCode"" IS NULL THEN 'Non-Item' ELSE COALESCE(I.""U_SegmentType"", 'Unassigned') END AS ""U_SegmentType"",#(lf)    COALESCE(T1.""ItemCode"", '(No Item)') AS ""ItemCode"",#(lf)    COALESCE(I.""ItemName"", T1.""Dscription"", 'Unknown') AS ""ItemName"",#(lf)    COALESCE(T1.""Quantity"", 0) * -1 AS ""Qty"",#(lf)    (COALESCE(T1.""LineTotal"", 0)#(lf)        + CASE#(lf)            WHEN TT.""SumLineTotal"" = 0 OR TT.""SumLineTotal"" IS NULL THEN 0#(lf)            ELSE (COALESCE(T1.""LineTotal"", 0) * COALESCE(T0.""DiscSum"", 0) * -1) / TT.""SumLineTotal""#(lf)          END#(lf)    ) * -1 AS ""Sales"",#(lf)    CASE#(lf)        WHEN T1.""ItemCode"" IS NULL THEN 0#(lf)        ELSE COALESCE(T1.""StockValue"", 0) * -1#(lf)    END AS ""COGS""#(lf)FROM ""CANON"".""ORIN"" T0#(lf)INNER JOIN ""CANON"".""RIN1"" T1 ON T0.""DocEntry"" = T1.""DocEntry""#(lf)LEFT JOIN CrTotals TT ON TT.""DocEntry"" = T0.""DocEntry""#(lf)LEFT JOIN ""CANON"".""OCRD"" C ON C.""CardCode"" = T0.""CardCode""#(lf)LEFT JOIN ""CANON"".""OITM"" I ON I.""ItemCode"" = T1.""ItemCode""#(lf)LEFT JOIN ""CANON"".""OSLP"" S ON S.""SlpCode"" = T0.""SlpCode""#(lf)WHERE#(lf)    T1.""ItemCode"" IS NOT NULL#(lf)    OR (#(lf)        T1.""ItemCode"" IS NULL#(lf)        AND COALESCE(T1.""LineTotal"", 0) <> 0#(lf)        AND (T1.""AcctCode"" LIKE '45%' OR T1.""AcctCode"" LIKE '46%')#(lf)    )#(lf)UNION ALL#(lf)SELECT * FROM WarrantyAP#(lf)UNION ALL#(lf)SELECT * FROM WarrantyAPCredit;")
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

