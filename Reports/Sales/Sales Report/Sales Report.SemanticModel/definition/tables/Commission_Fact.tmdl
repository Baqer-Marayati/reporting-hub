table Commission_Fact
	lineageTag: cf01a2b3-4567-4890-abcd-ef0123456789

	column QuarterLabel
		dataType: string
		lineageTag: cf01a2b3-0001-4000-8000-000000000001
		summarizeBy: none
		sourceColumn: QuarterLabel

