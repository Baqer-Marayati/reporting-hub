	measure TotalRevenueBudgetYTD_new = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			VAR TodayDate = TODAY()
			VAR YearStartDate =DATE(Year(Today()), 1,1)
			   -- Default to 30/06 fiscal year end
			
			   
			Var FiscalEndText = accountingPeriods[FiscalYearEnd]
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			VAR Result =
			    SWITCH(
			        TRUE(),
			        Period = "This fiscal year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Income",
			                    DATESBETWEEN(glBudgetEntries[date],FiscalYearStart, TodayDate)
			            ),
			        Period = "This calendar year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Income",
			                    DATESBETWEEN(glBudgetEntries[date], YearStartDate, TodayDate)
			            )
			
			    )
			 
			RETURN IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: dfa39e94-b93b-45b1-9014-37c875ef1697

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalCOGSBudgetYTD_new = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			VAR TodayDate = TODAY()
			
			
			VAR YearStartDate =DATE(Year(Today()), 1,1)
			
			   
			Var FiscalEndText = accountingPeriods[FiscalYearEnd]
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			-- Final result
			VAR Result =
			    SWITCH(
			        TRUE(),
			        
			        Period = "This fiscal year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Cost of Goods Sold",
			                    DATESBETWEEN(glBudgetEntries[date], FiscalYearStart, TodayDate)
			            ),
			        -- Year to date (use fiscal year start logic whether fiscal selected or not)
			        Period = "This calendar year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Cost of Goods Sold",
			                    DATESBETWEEN(glBudgetEntries[date], YearStartDate, TodayDate)
			            )
			
			    )
			 
			RETURN IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: 6387c382-381b-40e4-a560-83300fa6db15

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalExpenseBudgetYTD_new = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			VAR TodayDate = TODAY()
			
			 
			-- Default fiscal end to 30/06 if not selected
			
			 
			-- Fiscal year start logic
			VAR YearStartDate =DATE(Year(Today()), 1,1)
			    
			    
			Var FiscalEndText = accountingPeriods[FiscalYearEnd]
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			 
			-- Final result
			VAR Result =
			    SWITCH(
			        TRUE(),
			      
			        Period = "This fiscal year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Expense",
			                    DATESBETWEEN(glBudgetEntries[date], FiscalYearStart, TodayDate)
			            ),
			        -- Year to date (use fiscal year start logic whether fiscal selected or not)
			        Period = "This calendar year",
			            CALCULATE(
			                SUM(glBudgetEntries[amount]),
			                    glBudgetEntries[accountCategory] = "Expense",
			                    DATESBETWEEN(glBudgetEntries[date], YearStartDate, TodayDate)
			            )
			
			    )
			 
			RETURN IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: 370465a9-d8ae-4f6f-95c3-ee59602fc937

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalBudget = ```
			
			VAR StartDate = [StartDate]
			VAR EndDate= [EndDate]
			
			VAR Result =           
			    CALCULATE(
			        SUM(glBudgetEntries[amount]),
			        FILTER(
			            glBudgetEntries,
			            glBudgetEntries[accountCategory] = "Expense" && glBudgetEntries[accountType] = "Posting" && glBudgetEntries[incomeBalance] = "Income Statement"
			        ),       
			        FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: b69cfb0c-bef0-47f1-9240-d4630379effa

	measure Remaining =
			
			IF(
			    ISBLANK([TotalBudget]) || [TotalBudget] = 0,
			    BLANK(),
			    [TotalBudget] - ([ActualSpend] + [CommittedPO] + [UnCommittedPO])
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: d6316b65-f834-44e8-acde-b9b8b82a83af

	measure TotalCommitment = [ActualSpend] + [CommittedPO] + [UnCommittedPODynamic]
		lineageTag: e8319beb-fa6a-461b-90b1-39a9e396ea5e

	measure TotalBudgetDynamic = ```
			
			//Get value of dimension code slicer
			VAR DimSelected = SELECTEDVALUE(DimensionCodeTable[dimensionCodeNumberName]) 
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			// Get value of dimension code number  - either globalDimension1 or globalDimension2
			VAR DimNoSelected =  
			    FIRSTNONBLANK(
			        CALCULATETABLE(
			            VALUES(DimensionCodeTable[dimensionCodeNo]),
			            DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			        ),
			        1
			    )
			
			VAR DimensionCodesToFilter = 
			    CALCULATETABLE(
			        VALUES(DimensionCodeTable[dimensionCode]),
			        DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			    )
			
			VAR Result =           
			    CALCULATE(
			        SUM(glBudgetEntries[amount]),
			        FILTER(
			            glBudgetEntries,
			            glBudgetEntries[accountCategory] = "Expense" 
			            && glBudgetEntries[accountType] = "Posting" 
			            && glBudgetEntries[incomeBalance] = "Income Statement"
			            && IF(
			                DimNoSelected = "shortcutDimension1Code",
			                glBudgetEntries[globalDimension1Code] IN DimensionCodesToFilter,
			                IF(
			                    DimNoSelected = "shortcutDimension2Code",
			                    glBudgetEntries[globalDimension2Code] IN DimensionCodesToFilter,
			                    TRUE()
			                )
			            )
			        ),
			        FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		lineageTag: bbc5f415-673d-4691-8466-7aae00566e71

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalCommitmentDynamic = [ActualSpendDynamic] + [CommittedPODynamic] + [UnCommittedPODynamic]
		lineageTag: 916dab51-aa0c-4ac0-bdb7-b70c48de5564

	measure TotalPercentageUsedText =
			
			ROUND(DIVIDE(([TotalBudget] - [Remaining]), [TotalBudget]) * 100, 2) & "% used"
		lineageTag: 8d8cda12-45cb-40e1-996d-2046a190d819

