table DateFilters
	lineageTag: cd7f8a38-bf6f-454a-affc-6e68ecf805f9

	measure StartDate = ```
			
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			VAR Today = [TodayLocal]
			
			VAR StartOfWeek = Today - WEEKDAY(Today, 2) + 1
			VAR FiscalQuarterStart = [FiscalQuarterStart]
			VAR FiscalYearStart = [FiscalYearStart]
			
			VAR Result =
			    SWITCH(
			        SelectedPeriod,
			        "This week", StartOfWeek,
			        "This month", DATE(YEAR(Today), MONTH(Today), 1),
			        "This quarter", FiscalQuarterStart,
			        "This fiscal year", FiscalYearStart,
			        "This calendar year", DATE(YEAR(Today), 1, 1),
			        BLANK()
			    )    
			RETURN Result
			```
		formatString: General Date
		lineageTag: 8c714fc3-b54c-482d-9a03-7bed87a9d249

	measure EndDate =
			
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			VAR Today = [TodayLocal]
			
			VAR WeekToDate = Today
			VAR MonthToDate = Today
			VAR FiscalQuarterEnd = Today
			VAR FiscalYearToDate = Today
			VAR CalendarYearToDate = Today
			
			VAR Result =
			    SWITCH(
			        SelectedPeriod,
			        "This week", WeekToDate,
			        "This month", MonthToDate,
			        "This quarter", FiscalQuarterEnd,
			        "This fiscal year", FiscalYearToDate,
			        "This calendar year", CalendarYearToDate,
			        BLANK()
			    )
			RETURN Result
		formatString: General Date
		lineageTag: 416eee32-f2c2-4125-8fb5-1d28d98700af

	measure FiscalQuarterEnd = ```
			
			VAR Today = [TodayLocal]
			
			VAR Result = 
			CALCULATE(
			    MAX(DateTableCommitment[Date]),
			    FILTER(
			        DateTableCommitment,
			        QUARTER(DateTableCommitment[Date]) = QUARTER([TodayLocal]) &&
			        YEAR(DateTableCommitment[Date]) = YEAR([TodayLocal])
			    )
			)
			RETURN Result
			```
		formatString: General Date
		lineageTag: a4bf5789-a0f4-411b-af82-5f23b1c9cf83

	measure FiscalQuarterStart = ```
			
			VAR Today = [TodayLocal]
			
			VAR Result = 
			CALCULATE(
			    MIN(DateTableCommitment[Date]),
			    FILTER(
			        DateTableCommitment,
			        QUARTER(DateTableCommitment[Date]) = QUARTER(Today) &&
			        YEAR(DateTableCommitment[Date]) = YEAR(Today)
			    )
			)
			RETURN Result
			```
		formatString: General Date
		lineageTag: 1ed4287b-9461-4c83-98cc-d10e054c65a0

	measure FiscalYearEndDate = ```
			EDATE([FiscalYearStart], 12) - 1 //Assuming fiscal year is always 12 monthsMeasure = 
			```
		lineageTag: 62acfbdc-a17f-471e-9a0f-200fc23206a6

	measure FiscalYearStart =
			
			VAR Today = [TodayLocal]
			VAR CurrentFiscalYearStart =
			    CALCULATE(
			        MAX(accountingPeriods[startingDate]),
			        FILTER(
			            accountingPeriods,
			            accountingPeriods[newFiscalYear] = TRUE() &&
			            accountingPeriods[closed] = FALSE() &&
			            accountingPeriods[startingDate] <= Today
			        )
			    )
			VAR NextFiscalYearStart =
			    CALCULATE(
			        MIN(accountingPeriods[startingDate]),
			        FILTER(
			            accountingPeriods,
			            accountingPeriods[newFiscalYear] = TRUE() &&
			            accountingPeriods[closed] = FALSE() &&
			            accountingPeriods[startingDate] > Today
			        )
			    )
			VAR Result =
			    IF(
			        ISBLANK(CurrentFiscalYearStart),
			        EDATE(NextFiscalYearStart, -12),
			        CurrentFiscalYearStart
			    )
			RETURN Result
		formatString: General Date
		lineageTag: 086f90af-1b2a-4674-9622-c6876e2d018d

	measure QuarterToday = QUARTER([TodayLocal])
		formatString: 0
		lineageTag: bda6990b-c930-4a7a-8b17-9332b59f521b

	measure YearEnd = DATE(YEAR([TodayLocal]), 12, 31)
		formatString: General Date
		lineageTag: 2c3b861b-30ea-4975-b1b7-91f7d199dc92

	column id
		formatString: 0
		lineageTag: 78464906-d85f-43d7-b65c-01e2280e22f6
		summarizeBy: sum
