		annotation SummarizationSetBy = Automatic

	partition DateFilters = calculated
		mode: import
		source =
				DATATABLE(
				    "id", INTEGER,
				    "fiscalMonth", INTEGER,
				    "value", STRING,
				    "label", STRING,
				    {
				        {1, 1, "31/12", "Jan – Dec"},
				        {2, 2, "31/01", "Feb – Jan"},
				        {3, 3, "28/02", "Mar – Feb"},   // Consider leap year handling separately
				        {4, 4, "31/03", "Apr – Mar"},
				        {5, 5, "30/04", "May – Apr"},
				        {6, 6, "31/05", "Jun – May"},
				        {7, 7, "30/06", "Jul – Jun"},
				        {8, 8, "31/07", "Aug – Jul"},
				        {9, 9, "31/08", "Sep – Aug"},
				        {10, 10, "30/09", "Oct – Sep"},
				        {11, 11, "31/10", "Nov – Oct"},
				        {12, 12, "30/11", "Dec – Nov"}
				    }
				)

	annotation PBI_Id = 9090a04cafd2416da57df2d4c04585a2

