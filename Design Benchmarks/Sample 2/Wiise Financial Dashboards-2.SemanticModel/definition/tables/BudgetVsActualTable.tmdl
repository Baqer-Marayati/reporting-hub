	measure NewDynamicBudget = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			-- Fiscal year start logic
			
			 
			-- Start of the week (Monday)
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfThisMonth= Date(YEAR(TodayDate), MONTH(TodayDate), 1)
			 
			-- Final result
			VAR Result =
			    SWITCH(
			        TRUE(),
			 
			        
			 
			        -- Week to date
			        Period = "This week",
			            CALCULATE(
			                SUM(glBudgetEntries[Amount]),
			                glBudgetEntries[accountCategory] = "Income",
			                DATESBETWEEN(glBudgetEntries[date], StartOfThisMonth, TodayDate)
			            ),
			 
			        -- Month to date
			        Period = "This month",
			            CALCULATE(
			                SUM(glBudgetEntries[Amount]),
			                glBudgetEntries[accountCategory] = "Income",
			                DATESBETWEEN(glBudgetEntries[date], StartOfThisMonth, TodayDate)
			            ),
			 
			        -- Quarter to date
			        Period = "This quarter",
			            CALCULATE(
			                SUM(glBudgetEntries[Amount]),
			                glBudgetEntries[accountCategory] = "Income",
			                DATESBETWEEN(glBudgetEntries[date], StartOfThisQuarter, TodayDate)
			            ),
			 
			        --Fiscal year selection 
			        Period = "This fiscal year",
			            CALCULATE(
			                SUM(glBudgetEntries[Amount]),
			                glBudgetEntries[accountCategory] = "Income",
			                DATESBETWEEN(glBudgetEntries[date], FiscalYearStart, TodayDate)
			            ),
			        --Calendar year to date
			        Period = "This calendar year",
			            CALCULATE(
			                SUM(glBudgetEntries[Amount]),
			                glBudgetEntries[accountCategory] = "Income",
			                DATESBETWEEN(glBudgetEntries[date], YearStartDate, TodayDate)
			            )
			 
			       
			    )
			 
			RETURN IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: 019e0b1e-d1fa-484c-9857-fc242d2cae03

		annotation PBI_FormatHint = {"isGeneralNumber":true}

