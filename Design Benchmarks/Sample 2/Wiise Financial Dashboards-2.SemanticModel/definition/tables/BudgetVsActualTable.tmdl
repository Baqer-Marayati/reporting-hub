	measure BackgroundColorForIncomePct = ```
			
			
			
			
			VAR ChangePct = IF([NewDynamicIncomePrevious]=0,1,DIVIDE([NewDynamicIncome] - [NewDynamicIncomePrevious], [NewDynamicIncomePrevious]))
			
			
			VAR Percentage = ChangePct*100
			VAR Col = 
			
			    SWITCH(
			
			        TRUE(),
			
			       Percentage = 0, "Grey",
			
			        Percentage > 1, "Green",
			
			        Percentage < 0, "Red",
			
			        "Grey"  -- fallback
			    )
			 
			
			RETURN Col
			```
