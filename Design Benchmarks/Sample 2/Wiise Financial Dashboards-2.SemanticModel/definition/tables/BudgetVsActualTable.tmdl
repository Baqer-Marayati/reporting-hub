	column DynamicXAxis = ```
			
			VAR SelectedDate = SELECTEDVALUE(BudgetVsActualTable[Date])
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			VAR FiscalEndText = SELECTEDVALUE(FiscalYearSelection[value])
			VAR TodayDate = TODAY()
			 
			// Fiscal year calculations
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			VAR FiscalYear = IF(MONTH(SelectedDate) > FiscalMonth, YEAR(SelectedDate) + 1, YEAR(SelectedDate))
			 
			// Week calculations
			VAR WeekStartDate = SelectedDate - WEEKDAY(SelectedDate, 2) + 1  // Monday
			VAR WeekEndDate = WeekStartDate + 6  // Sunday
			 
			// Default view - last 3 years comparison
			VAR DefaultView = 
			    IF(
			        DATEDIFF(DATE(YEAR(TodayDate)-3, 1, 1), SelectedDate, DAY) >= 0,
			        "FY" & (YEAR(SelectedDate) + IF(MONTH(SelectedDate) > FiscalMonth, 1, 0)) & " " & LEFT([Month], 3)
			    )
			 
			RETURN
			SWITCH(
			    TRUE(),
			    // --- When no period is selected (default view) ---
			    ISBLANK(SelectedPeriod) && ISBLANK(FiscalEndText),
			        DefaultView,
			    // --- Week-to-date view ---
			    SelectedPeriod = "Week to date",
			        UPPER(LEFT(FORMAT(SelectedDate, "dddd"), 3)) & " " & DAY(SelectedDate),
			    // --- Month-to-date view ---
			    SelectedPeriod = "Month to date",
			        FORMAT(DAY(SelectedDate), "00") & " " & LEFT([Month], 3),
			    // --- Quarter-to-date view ---
			    SelectedPeriod = "Quarter to date",
			        "W" & [WeekNum] & ": " & 
			        FORMAT(WeekStartDate, "dd") & "-" & 
			        FORMAT(WeekEndDate, "dd ") & 
			        LEFT(FORMAT(WeekStartDate, "MMMM"), 3),
			    // --- Year-to-date view ---
			    SelectedPeriod = "Year to date" && ISBLANK(FiscalEndText),
			        LEFT([Month], 3) & " " & [Year],
			    // --- Year-to-date view with fiscal year selected ---
			    SelectedPeriod = "Year to date" && NOT ISBLANK(FiscalEndText),
			        LEFT([Month], 3) & " FY" & RIGHT(FORMAT(FiscalYear, "0000"), 2),
			    // --- Fiscal year selected (without specific period) ---
			    NOT ISBLANK(FiscalEndText) && ISBLANK(SelectedPeriod),
			        "FY" & FiscalYear & " " & [Quarter],
			    // --- Fallback default ---
			    DefaultView
			)
			```
		lineageTag: 1d9da261-51bd-43ce-b4b1-b12ebc604161
		summarizeBy: none
		sortByColumn: XAxisSort

		annotation SummarizationSetBy = Automatic

	column XAxisSort = ```
			
			VAR Dt = BudgetVsActualTable[Date]
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			VAR FiscalEndText = SELECTEDVALUE(FiscalYearSelection[value])
			VAR Year = YEAR(Dt)
			VAR Month = MONTH(Dt)
			VAR Day = DAY(Dt)
			VAR WeekNum = WEEKNUM(Dt, 2)
			 
			-- Fiscal Year calculation
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			VAR FiscalYear = IF(Month > FiscalMonth, Year + 1, Year)
			 
			RETURN
			SWITCH(
			    TRUE(),
			 
			    // Week to date: sort by full date
			    SelectedPeriod = "Week to date", Dt,
			 
			    // Month to date: sort by full date
			    SelectedPeriod = "Month to date", Dt,
			 
			    // Quarter to date: sort by fiscal year * 100 + week number
			    SelectedPeriod = "Quarter to date", FiscalYear * 100 + WeekNum,
			 
			    // Year to date: sort by fiscal year * 100 + month number
			    SelectedPeriod = "Year to date", FiscalYear * 100 + Month,
			 
			    // Fallback: sort by fiscal year * 100 + month number
			    FiscalYear * 100 + Month
			)
			```
		lineageTag: 3a9f6355-098f-4b5a-8c77-d24afa6cb8eb
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column XAxisLabel = ```
			
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI], "Year to date") 
			VAR Dt = BudgetVsActualTable[Date]
			 
			-- Fiscal Year end month (default = June = 6)
			VAR FiscalMonthEnd = SELECTEDVALUE(FiscalYearSelection[fiscalMonth], 6)
			 
			-- Compute Fiscal Year based on fiscal end month
			VAR FiscalYear = 
			    YEAR(Dt) + IF(MONTH(Dt) <= FiscalMonthEnd, 0, 1)
			 
			-- Label when WTD is selected
			VAR Label_WTD = FORMAT(Dt, "dd MMM") & " FY" & FiscalYear
			 
			-- Fallback label (for now)
			VAR DefaultLabel = FORMAT(Dt, "MMM yyyy")
			 
			RETURN 
			    SWITCH( 
			        TRUE(), 
			        SelectedPeriod = "Week to date", Label_WTD,
			        DefaultLabel
			    )
			```
		lineageTag: 9f73a23b-ca87-44b6-b2da-737517b8556b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Weeknum = WEEKNUM(BudgetVsActualTable[Date], 2)
		formatString: 0
		lineageTag: 844a554a-278c-4519-87c2-0cffddf1cb8c
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column IsVisibleOnXAxis = ```
			
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI_ID], "4")
			VAR CurrentDate = TODAY()
			VAR TargetDate = BudgetVsActualTable[Date]
			 
			VAR StartOfLast2Years = DATE(YEAR(CurrentDate) - 1, 7, 1) -- Start of last fiscal year
			-- Adjust "7" to "1" if your fiscal year starts in January
			 
			RETURN
			    SWITCH(
			        TRUE(),
			        SelectedPeriod = "1" && TargetDate >= CurrentDate - 28, TRUE(),
			        SelectedPeriod = "2" && TargetDate >= EOMONTH(CurrentDate, -12) + 1, TRUE(),
			        SelectedPeriod = "3" && TargetDate >= EOMONTH(CurrentDate, -18) + 1, TRUE(),
			        (SelectedPeriod = "4" || ISBLANK(SelectedPeriod)) && TargetDate >= StartOfLast2Years, TRUE(),
			        FALSE
			    )
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 5665a7c9-43c8-4a17-ab39-7eb92dff3063
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Column
		type: calculated
		lineageTag: 1055a9d3-7e75-4980-9bbb-2f5d69f93189
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	column XAxisLabel_WTD =
			
			VAR Dt = BudgetVsActualTable[Date]
			VAR FiscalMonthEnd = SELECTEDVALUE(FiscalYearSelection[fiscalMonth], 6)  -- default: June
			VAR FiscalYear = YEAR(Dt) + IF(MONTH(Dt) <= FiscalMonthEnd, 0, 1)
			RETURN FORMAT(Dt, "dd MMM") & " FY" & FiscalYear
		lineageTag: 27cd6d97-142d-44c9-a2be-0ca3f34ef5b3
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition BudgetVsActualTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2023, 1, 1), DATE(2026, 12, 31)),
				    "Year", YEAR([Date]),
				    "Month", FORMAT([Date], "MMMM"),
				    "Month Number", MONTH([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Weekday", FORMAT([Date], "dddd")
				)

	annotation PBI_Id = 204ff07cb0824e82a3f41f5e7b129ce4

