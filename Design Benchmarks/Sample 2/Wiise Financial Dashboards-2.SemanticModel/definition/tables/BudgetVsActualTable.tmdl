	measure ShowOnXAxis = ```
			
			VAR SelectedPeriod = SELECTEDVALUE(PeriodTable[Period], "YTD")
			VAR CurrentDate = TODAY()
			VAR TargetDate = MAX(BudgetVsActualTable[Date])
			 
			-- Define logic ranges
			VAR Last4Weeks = CurrentDate - 28
			VAR Last12Months = EOMONTH(CurrentDate, -12) + 1
			VAR Last6Quarters = EOMONTH(CurrentDate, -18) + 1
			VAR Last3FiscalYears = DATE(YEAR(CurrentDate) - 2, 7, 1)
			 
			RETURN
			    SWITCH(
			        TRUE(),
			        SelectedPeriod = "WTD" && TargetDate >= Last4Weeks, 1,
			        SelectedPeriod = "MTD" && TargetDate >= Last12Months, 1,
			        SelectedPeriod = "QTD" && TargetDate >= Last6Quarters, 1,
			        SelectedPeriod = "YTD" && TargetDate >= Last3FiscalYears, 1,
			        ISBLANK(SelectedPeriod) && TargetDate >= Last3FiscalYears, 1,
			        0
			    )
			```
		formatString: 0
		lineageTag: 93f916e9-e310-41bf-8bb6-71b4c825e56a

