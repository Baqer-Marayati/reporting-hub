	measure ActualAmountDynamic = ```
			
			VAR SelectedDimName = SELECTEDVALUE('dimensions'[Code])         -- e.g., "Department"
			VAR SelectedDimValue = SELECTEDVALUE('dimensionValues'[Code])   -- e.g., "DEPT01"
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			
			VAR SelectedAcctCategory = SELECTEDVALUE(AccountCategoryTable[Category])  -- "Income" or "Expense"
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			
			 VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			-- Fiscal year start logic
			VAR Multiplier=IF(SelectedAcctCategory="Income", -1, 1)
			 
			-- Start of the week (Monday)
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfThisMonth= Date(YEAR(TodayDate), MONTH(TodayDate), 1)
			 
			-- Find the dynamic column from ColumnMapActual
			VAR TargetColumn =
			    CALCULATE(
			        SELECTEDVALUE(ColumnMapGLE[ColumnName]),
			        ColumnMapGLE[dimensions.code] = SelectedDimName
			    )
			 
			-- Final Result
			VAR Result =
			    SWITCH(
			        TRUE(),
			 
			        SelectedPeriod = "This week",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]) * Multiplier,
			            FILTER(
			                ALL(generalLedgerEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "globalDimension1Code", generalLedgerEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", generalLedgerEntries[globalDimension2Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension3Code", generalLedgerEntries[shortcutDimension3Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension4Code", generalLedgerEntries[shortcutDimension4Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension5Code", generalLedgerEntries[shortcutDimension5Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension6Code", generalLedgerEntries[shortcutDimension6Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension7Code", generalLedgerEntries[shortcutDimension7Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension8Code", generalLedgerEntries[shortcutDimension8Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                generalLedgerEntries[accountCategory] = SelectedAcctCategory &&
			                generalLedgerEntries[PostingDate] >= StartOfWeek &&
			                generalLedgerEntries[PostingDate] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This month",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]) * Multiplier,
			            FILTER(
			                ALL(generalLedgerEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "globalDimension1Code", generalLedgerEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", generalLedgerEntries[globalDimension2Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension3Code", generalLedgerEntries[shortcutDimension3Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension4Code", generalLedgerEntries[shortcutDimension4Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension5Code", generalLedgerEntries[shortcutDimension5Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension6Code", generalLedgerEntries[shortcutDimension6Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension7Code", generalLedgerEntries[shortcutDimension7Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension8Code", generalLedgerEntries[shortcutDimension8Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                generalLedgerEntries[accountCategory] = SelectedAcctCategory &&
			                generalLedgerEntries[PostingDate] >= StartOfThisMonth &&
			                generalLedgerEntries[PostingDate] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This quarter",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]) * Multiplier,
			            FILTER(
			                ALL(generalLedgerEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "globalDimension1Code", generalLedgerEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", generalLedgerEntries[globalDimension2Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension3Code", generalLedgerEntries[shortcutDimension3Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension4Code", generalLedgerEntries[shortcutDimension4Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension5Code", generalLedgerEntries[shortcutDimension5Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension6Code", generalLedgerEntries[shortcutDimension6Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension7Code", generalLedgerEntries[shortcutDimension7Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension8Code", generalLedgerEntries[shortcutDimension8Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                generalLedgerEntries[accountCategory] = SelectedAcctCategory&&
			                generalLedgerEntries[PostingDate] >= StartOfThisQuarter &&
			                generalLedgerEntries[PostingDate] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This fiscal year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]) * Multiplier,
			            FILTER(
			                ALL(generalLedgerEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "globalDimension1Code", generalLedgerEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", generalLedgerEntries[globalDimension2Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension3Code", generalLedgerEntries[shortcutDimension3Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension4Code", generalLedgerEntries[shortcutDimension4Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension5Code", generalLedgerEntries[shortcutDimension5Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension6Code", generalLedgerEntries[shortcutDimension6Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension7Code", generalLedgerEntries[shortcutDimension7Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension8Code", generalLedgerEntries[shortcutDimension8Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                generalLedgerEntries[accountCategory] = SelectedAcctCategory &&
			                generalLedgerEntries[PostingDate] >= FiscalYearStart &&
			                generalLedgerEntries[PostingDate] <= TodayDate
			            )
			        ),
			
			        SelectedPeriod = "This calendar year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]) * Multiplier,
			            FILTER(
			                ALL(generalLedgerEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "globalDimension1Code", generalLedgerEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", generalLedgerEntries[globalDimension2Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension3Code", generalLedgerEntries[shortcutDimension3Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension4Code", generalLedgerEntries[shortcutDimension4Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension5Code", generalLedgerEntries[shortcutDimension5Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension6Code", generalLedgerEntries[shortcutDimension6Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension7Code", generalLedgerEntries[shortcutDimension7Code] = SelectedDimValue,
			                    TargetColumn = "shortcutDimension8Code", generalLedgerEntries[shortcutDimension8Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                generalLedgerEntries[accountCategory] = SelectedAcctCategory &&
			                generalLedgerEntries[PostingDate] >= YearStartDate &&
			                generalLedgerEntries[PostingDate] <= TodayDate
			            )
			        )
			 
			       
			    )
			 
			RETURN IF(ISBLANK(Result), 0, ABS(Result))
			```
		lineageTag: 059ddf82-4195-495d-a61c-0b392f881e62

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure BudgetAmountDynamic = ```
			
			VAR SelectedDimName = SELECTEDVALUE('dimensions'[Code])          -- e.g., "Department"
			VAR SelectedDimValue = SELECTEDVALUE('dimensionValues'[Code])    -- e.g., "DEPT01"
			VAR SelectedPeriod = SELECTEDVALUE(Period[KPI])
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			VAR SelectedBudgetName = SELECTEDVALUE(glBudgetEntries[budgetName])
			
			 
			VAR SelectedAcctCategory = SELECTEDVALUE(AccountCategoryTable[Category])  -- "Income" or "Expense"
			
			 
			 
			
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			
			 VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			-- Fiscal year start logic
			VAR Multiplier=IF(SelectedAcctCategory="Income", -1, 1)
			 
			-- Start of the week (Monday)
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfThisMonth= Date(YEAR(TodayDate), MONTH(TodayDate), 1)
			 
			-- Find correct column from ColumnMap
			VAR TargetColumn =
			    CALCULATE(
			        MAX(ColumnMapGL[ColumnName]),
			        FILTER(
			            ColumnMapGL,
			            ColumnMapGL[dimensions.code] = SelectedDimName
			        )
			    )
			 
			-- Final Result
			VAR Result =
			    SWITCH(
			        TRUE(),
			 
			        SelectedPeriod = "This week",
			        CALCULATE(
			            SUM(glBudgetEntries[Amount]),
			            FILTER(
			                ALL(glBudgetEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "budgetDimension1Code", glBudgetEntries[budgetDimension1Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension2Code", glBudgetEntries[budgetDimension2Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension3Code", glBudgetEntries[budgetDimension3Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension4Code", glBudgetEntries[budgetDimension4Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension1Code", glBudgetEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", glBudgetEntries[globalDimension2Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                glBudgetEntries[accountCategory] = SelectedAcctCategory &&
			                // glBudgetEntries[budgetName]=SelectedBudgetName &&
			                glBudgetEntries[date] >= StartOfThisMonth &&
			                glBudgetEntries[date] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This month",
			        CALCULATE(
			            SUM(glBudgetEntries[Amount]),
			            FILTER(
			                ALL(glBudgetEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "budgetDimension1Code", glBudgetEntries[budgetDimension1Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension2Code", glBudgetEntries[budgetDimension2Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension3Code", glBudgetEntries[budgetDimension3Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension4Code", glBudgetEntries[budgetDimension4Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension1Code", glBudgetEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", glBudgetEntries[globalDimension2Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                glBudgetEntries[accountCategory] = SelectedAcctCategory &&
			                // glBudgetEntries[budgetName]=SelectedBudgetName &&
			                glBudgetEntries[date] >= StartOfThisMonth &&
			                glBudgetEntries[date] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This quarter",
			        CALCULATE(
			            SUM(glBudgetEntries[Amount]),
			            FILTER(
			                ALL(glBudgetEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "budgetDimension1Code", glBudgetEntries[budgetDimension1Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension2Code", glBudgetEntries[budgetDimension2Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension3Code", glBudgetEntries[budgetDimension3Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension4Code", glBudgetEntries[budgetDimension4Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension1Code", glBudgetEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", glBudgetEntries[globalDimension2Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                glBudgetEntries[accountCategory] = SelectedAcctCategory &&
			                glBudgetEntries[budgetName]=SelectedBudgetName &&
			                glBudgetEntries[date]>=StartOfThisQuarter &&
			                glBudgetEntries[date]<=TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This fiscal year",
			        CALCULATE(
			            SUM(glBudgetEntries[Amount]),
			            FILTER(
			                ALL(glBudgetEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "budgetDimension1Code", glBudgetEntries[budgetDimension1Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension2Code", glBudgetEntries[budgetDimension2Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension3Code", glBudgetEntries[budgetDimension3Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension4Code", glBudgetEntries[budgetDimension4Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension1Code", glBudgetEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", glBudgetEntries[globalDimension2Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                glBudgetEntries[accountCategory] = SelectedAcctCategory &&
			                glBudgetEntries[budgetName]=SelectedBudgetName &&
			                glBudgetEntries[date] >= FiscalYearStart &&
			                glBudgetEntries[date] <= TodayDate
			            )
			        ),
			 
			        SelectedPeriod = "This calendar year",
			        CALCULATE(
			            SUM(glBudgetEntries[Amount]),
			            FILTER(
			                ALL(glBudgetEntries),
			                SWITCH (
			                    TRUE(),
			                    TargetColumn = "budgetDimension1Code", glBudgetEntries[budgetDimension1Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension2Code", glBudgetEntries[budgetDimension2Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension3Code", glBudgetEntries[budgetDimension3Code] = SelectedDimValue,
			                    TargetColumn = "budgetDimension4Code", glBudgetEntries[budgetDimension4Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension1Code", glBudgetEntries[globalDimension1Code] = SelectedDimValue,
			                    TargetColumn = "globalDimension2Code", glBudgetEntries[globalDimension2Code] = SelectedDimValue,
			                    FALSE
			                ) &&
			                glBudgetEntries[accountCategory] = SelectedAcctCategory &&
			                glBudgetEntries[budgetName]=SelectedBudgetName &&
			                glBudgetEntries[date] >= YearStartDate &&
			                glBudgetEntries[date] <= TodayDate
			            )
			        )
			        
			    )
			 
			RETURN IF(ISBLANK(Result), 0, ABS(Result))
			```
		lineageTag: 91a147ea-2a2f-4963-b7cc-845dfbcb414e

