	measure TestFiscalDateRange = ```
			
			VAR TodayDate = TODAY()
			VAR FiscalEndText = SELECTEDVALUE(FiscalYearSelection[value], "30/06")
			VAR FiscalDay = VALUE(LEFT(FiscalEndText, 2))
			VAR FiscalMonth = VALUE(RIGHT(FiscalEndText, 2))
			VAR FiscalYearEndThisYear = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			 
			VAR StartFiscalYear =
			    IF(
			        TodayDate <= FiscalYearEndThisYear,
			        DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1),
			        DATE(YEAR(TodayDate), FiscalMonth + 1, 1)
			    )
			VAR EndFiscalYear = EOMONTH(StartFiscalYear, 11)
			 
			RETURN
			    "Start: " & FORMAT(StartFiscalYear, "DD/MM/YYYY") &
			    " | End: " & FORMAT(EndFiscalYear, "DD/MM/YYYY")
			```
		lineageTag: f734305c-0270-4935-9814-cfcffcf7fa3d

	measure XAxisSelection = ```
			
			VAR SelectedPeriod = SELECTEDVALUE(PeriodTable[Period], "Year to date")
			VAR CurrentDate = TODAY()
			VAR FiscalEndText = SELECTEDVALUE(FiscalYearSelection[value], "30/06")
			VAR FiscalDay = VALUE(LEFT(FiscalEndText, 2))
			VAR FiscalMonth = VALUE(RIGHT(FiscalEndText, 2))
			 
			RETURN
			SWITCH(
			    TRUE(),
			    -- Week to date shows daily data
			    SelectedPeriod = "Week to date", 
			        FORMAT(SELECTEDVALUE('DateTable'[Date]), "ddd dd"),
			    -- Month to date shows daily data
			    SelectedPeriod = "Month to date", 
			        FORMAT(SELECTEDVALUE('DateTable'[Date]), "dd MMM"),
			    -- Quarter to date shows weekly data
			    SelectedPeriod = "Quarter to date", 
			        "Week " & SELECTEDVALUE('DateTable'[WeekNum]) & " (" & 
			        FORMAT(MIN('DateTable'[Date]), "dd MMM") & ")",
			    -- Year to date shows monthly data
			    SelectedPeriod = "Year to date", 
			        FORMAT(SELECTEDVALUE('DateTable'[Date]), "MMM yyyy"),
			    -- Default fallback (monthly)
			    FORMAT(SELECTEDVALUE('DateTable'[Date]), "MMM yyyy")
			)
			```
