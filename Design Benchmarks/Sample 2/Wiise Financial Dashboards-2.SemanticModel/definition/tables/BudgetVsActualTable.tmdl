	measure NewDynamicIncomePrevious = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			
			 
			
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			
			VAR DaysSinceFiscalStart = TodayDate-FiscalYearStart
			VAR PrevFiscalStart=EDATE(FiscalYearStart, -12)
			VAR PrevFiscalEndSameDay = PrevFiscalStart + DaysSinceFiscalStart
			
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			VAR LastYear = YEAR(TodayDate)-1
			VAR StartOfLastCalendarYear=DATE(LastYear,1, 1)
			VAR EndOfLastCalendarYTD=DATE(LastYear, MONTH(TodayDate), DAY(TodayDate))
			
			
			
			
			 
			--WTD
			
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfLastWeek = StartOfWeek-7
			VAR EndOfPrevWeekSameDay=TodayDate-7
			 
			
			 
			
			 
			-- MTD - Previous Month up to Same Day
			
			VAR StartOfCurrentMonth = DATE(YEAR(TodayDate), MONTH(TodayDate), 1)
			VAR StartOfPrevMonth=EDATE(StartOfCurrentMonth, -1)
			VAR DayofMonth=DAY(TodayDate)
			VAR LastDayOfPrevMonth=EOMONTH(StartOfPrevMonth, 0)
			VAR EndOfPrevMTD = If(DayofMonth >Day(LastDayOfPrevMonth),LastDayOfPrevMonth, StartOfPrevMonth+DayofMonth-1)
			
			 
			-- QTD
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfPrevQuarter = EDATE(StartOfThisQuarter, -3)
			VAR EndOfPrevQuarter = EOMONTH(StartOfPrevQuarter, 2)
			VAR EndOFPrevQTD =EDATE([TodayLocal], -3)
			
			
			 
			-- Calendar year
			
			
			
			
			
			 
			
			RETURN
			SWITCH(
			    TRUE(),
			    Period = "This week",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount])*-1,
			            generalLedgerEntries[accountCategory] = "Income",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfLastWeek, EndOfPrevWeekSameDay)
			        ),
			    Period = "This month",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount])*-1,
			            generalLedgerEntries[accountCategory] = "Income",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfPrevMonth, EndOfPrevMTD)
			        ),
			    Period = "This quarter",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount])*-1,
			            generalLedgerEntries[accountCategory] = "Income",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfPrevQuarter, EndOFPrevQTD)
			        ),
			    Period = "This fiscal year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount])*-1,
			            generalLedgerEntries[accountCategory] = "Income",
			            DATESBETWEEN(generalLedgerEntries[postingDate], PrevFiscalStart, PrevFiscalEndSameDay)
			        ),
			    Period = "This calendar year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount])*-1,
			            generalLedgerEntries[accountCategory] = "Income",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfLastCalendarYear, EndOfLastCalendarYTD)
			        )
			    
			)
			```
		lineageTag: bbb96a3b-ef8a-4e42-8510-494a42f53d70

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure NewDynamicExpensePrevious = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			VAR DaysSinceFiscalStart = TodayDate-FiscalYearStart
			VAR PrevFiscalStart=EDATE(FiscalYearStart, -12)
			VAR PrevFiscalEndSameDay = PrevFiscalStart + DaysSinceFiscalStart
			
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			VAR LastYear = YEAR(TodayDate)-1
			VAR StartOfLastCalendarYear=DATE(LastYear,1, 1)
			VAR EndOfLastCalendarYTD=DATE(LastYear, MONTH(TodayDate), DAY(TodayDate))
			
			
			
			
			 
			--WTD
			
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfLastWeek = StartOfWeek-7
			VAR EndOfPrevWeekSameDay=TodayDate-7
			 
			
			 
			
			 
			-- MTD - Previous Month up to Same Day
			
			VAR StartOfCurrentMonth = DATE(YEAR(TodayDate), MONTH(TodayDate), 1)
			VAR StartOfPrevMonth=EDATE(StartOfCurrentMonth, -1)
			VAR DayofMonth=DAY(TodayDate)
			VAR LastDayOfPrevMonth=EOMONTH(StartOfPrevMonth, 0)
			VAR EndOfPrevMTD = If(DayofMonth >Day(LastDayOfPrevMonth),LastDayOfPrevMonth, StartOfPrevMonth+DayofMonth-1)
			
			 
			-- QTD
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfPrevQuarter = EDATE(StartOfThisQuarter, -3)
			VAR EndOfPrevQuarter = EOMONTH(StartOfPrevQuarter, 2)
			VAR EndOfPrevQTD=EDATE([TodayLocal], -3)
			
			
			 
			-- Calendar year
			
			
			
			
			
			 
			
			RETURN
			SWITCH(
			    TRUE(),
			    Period = "This week",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]),
			            generalLedgerEntries[accountCategory] = "Expense",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfLastWeek, EndOfPrevWeekSameDay)
			        ),
			    Period = "This month",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]),
			            generalLedgerEntries[accountCategory] = "Expense",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfPrevMonth, EndOfPrevMTD)
			        ),
			    Period = "This quarter",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]),
			            generalLedgerEntries[accountCategory] = "Expense",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfPrevQuarter, EndOFPrevQTD)
			        ),
			    Period = "This fiscal year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]),
			            generalLedgerEntries[accountCategory] = "Expense",
			            DATESBETWEEN(generalLedgerEntries[postingDate], PrevFiscalStart, PrevFiscalEndSameDay)
			        ),
			    Period = "This calendar year",
			        CALCULATE(
			            SUM(generalLedgerEntries[Amount]),
			            generalLedgerEntries[accountCategory] = "Expense",
			            DATESBETWEEN(generalLedgerEntries[postingDate], StartOfLastCalendarYear, EndOfLastCalendarYTD)
			        )
			    
			)
			```
		lineageTag: 528a7c08-d4fd-486e-9656-a9a66b6032ae

