	measure GLActual1 = ```
			
			VAR Period = SELECTEDVALUE(PeriodTable[Period], BLANK())
			VAR FiscalEndText = SELECTEDVALUE(FiscalYearSelection[value], BLANK())
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			 
			-- If nothing is selected, return total
			VAR ReturnAll = ISBLANK(Period) && ISBLANK(FiscalEndText)
			 
			-- Default to fiscal end 30/06 if not selected
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			 
			-- Fiscal Year Start (e.g., July 1)
			VAR FiscalYearStart =
			    IF(
			        TodayDate <= FiscalYearEnd,
			        DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1),
			        DATE(YEAR(TodayDate), FiscalMonth + 1, 1)
			    )
			 
			-- Week start (Monday)
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			 
			-- Result based on selection
			VAR Result =
			    SWITCH(
			        TRUE(),
			        ReturnAll,
			            CALCULATE(
			                SUM(GeneralLedgerEntries[amount])
			            ),
			 
			        Period = "Week to date",
			            CALCULATE(
			                SUM(GeneralLedgerEntries[amount]),
			                DATESBETWEEN(GeneralLedgerEntries[PostingDate], StartOfWeek, TodayDate)
			            ),
			 
			        Period = "Month to date",
			            CALCULATE(
			                SUM(GeneralLedgerEntries[amount]),
			                DATESMTD(GeneralLedgerEntries[PostingDate])
			            ),
			 
			        Period = "Quarter to date",
			            CALCULATE(
			                SUM(GeneralLedgerEntries[amount]),
			                DATESQTD(GeneralLedgerEntries[PostingDate])
			            ),
			 
			        Period = "Year to date",
			            CALCULATE(
			                SUM(GeneralLedgerEntries[amount]),
			                DATESBETWEEN(GeneralLedgerEntries[PostingDate], FiscalYearStart, TodayDate)
			            )
			    )
			 
			RETURN
			    IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: 1371bc1b-36c3-46d7-a494-d234e59fe24a

