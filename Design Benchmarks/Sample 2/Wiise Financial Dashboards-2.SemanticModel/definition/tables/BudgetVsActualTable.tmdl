	measure RevenueCurrentLinear = ```
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			 
			-- Last 12 months window
			VAR Last12MonthsStartRaw = EDATE(TodayDate, -12) + 1
			VAR Last12MonthsStart = IF(Last12MonthsStartRaw < FiscalYearStart, FiscalYearStart, Last12MonthsStartRaw)
			 
			RETURN
			CALCULATE(
			    SUMX(
			    FILTER(
			        generalLedgerEntries,
			        generalLedgerEntries[accountType] = "Posting" &&
			        generalLedgerEntries[incomeBalance] = "Income Statement" &&
			        generalLedgerEntries[postingDate]>=Last12MonthsStartRaw &&
			        generalLedgerEntries[postingDate]<=TodayDate
			    ),
			    IF(generalLedgerEntries[accountCategory]="Income", 
			    generalLedgerEntries[amount]*-1, generalLedgerEntries[amount]
			    
			)))
			```
		lineageTag: 9aae43e0-4542-4d52-b442-7c0f726c283b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

