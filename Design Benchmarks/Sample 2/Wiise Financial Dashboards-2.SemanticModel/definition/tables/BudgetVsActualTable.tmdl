	measure NewDynamicIncome = ```
			
			VAR Period = SELECTEDVALUE(Period[KPI], BLANK())
			
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			VAR FiscalEndText=accountingPeriods[FiscalYearEnd]
			-- Default to 30/06 fiscal year end
			VAR FiscalDay = IF(ISBLANK(FiscalEndText), 30, VALUE(LEFT(FiscalEndText, 2)))
			VAR FiscalMonth = IF(ISBLANK(FiscalEndText), 6, VALUE(RIGHT(FiscalEndText, 2)))
			 
			-- Fiscal year start for current date
			VAR FiscalYearEnd = DATE(YEAR(TodayDate), FiscalMonth, FiscalDay)
			VAR FiscalYearStart = IF(TodayDate <= FiscalYearEnd, DATE(YEAR(TodayDate) - 1, FiscalMonth + 1, 1), DATE(YEAR(TodayDate), FiscalMonth + 1, 1))
			
			
			
			VAR StartOfThisMonth=Date(YEAR(TodayDate), Month(TodayDate),1)
			 
			
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			 
			VAR Result =
			    SWITCH(
			        TRUE(),
			        
			        Period = "This week",
			            CALCULATE(
			                SUM(generalLedgerEntries[Amount])*-1,
			                generalLedgerEntries[accountCategory] = "Income",
			                DATESBETWEEN(generalLedgerEntries[PostingDate], StartOfWeek, TodayDate)
			            ),
			        Period = "This month",
			            CALCULATE(
			                SUM(generalLedgerEntries[Amount])*-1,
			                generalLedgerEntries[accountCategory] = "Income",
			                DATESBETWEEN(generalLedgerEntries[PostingDate], StartOfThisMonth, TodayDate)
			            ),
			        Period = "This quarter",
			            CALCULATE(
			                SUM(generalLedgerEntries[Amount])*-1,
			                generalLedgerEntries[accountCategory] = "Income",
			                DATESBETWEEN(generalLedgerEntries[PostingDate], StartOfThisQuarter, TodayDate)
			            ),
			        Period = "This fiscal year",
			            CALCULATE(
			                SUM(generalLedgerEntries[Amount])*-1,
			                generalLedgerEntries[accountCategory] = "Income",
			                DATESBETWEEN(generalLedgerEntries[PostingDate], FiscalYearStart, TodayDate)
			            ),
			        Period = "This calendar year",
			            CALCULATE(
			                SUM(generalLedgerEntries[Amount])*-1,
			                generalLedgerEntries[accountCategory] = "Income",
			                DATESBETWEEN(generalLedgerEntries[PostingDate], YearStartDate, TodayDate)
			            )
			        
			    )
			 
			RETURN IF(ISBLANK(Result), 0, Result)
			```
		lineageTag: c0738070-a0fa-4f33-947e-aef54ff484df

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure NewKPIExpense = ```
			
			VAR ActualValue = [NewDynamicExpense]
			VAR BudgetValue = [NewDynamicBudgetExpense]
			 
			-- Format values
			VAR Actual = FORMAT(ActualValue, "$#,##0")
			VAR Budget = FORMAT(BudgetValue, "$#,##0")
			 
			-- Calculate percentage variance
			VAR ChangePct = DIVIDE(ActualValue - BudgetValue, BudgetValue, 0)
			 
			-- Arrow indicator
			VAR Arrow = IF(ChangePct >= 0, "▲", "▼")
			 
			-- Format % without sign, add manually
			VAR ChangePctFormatted = FORMAT(ABS(ChangePct), "0.00%")
			 
			-- Final display
			RETURN
			    Actual
			```
		lineageTag: 36960a26-a5e2-4e57-b687-b841494191b3

	measure NewKPIIncome = ```
			
			
			VAR ActualValue = [NewDynamicIncome] 
			
			VAR BudgetValue = [NewDynamicBudget] 
			
			  
			
			-- Format actual and budget 
			
			VAR Actual = FORMAT(ActualValue, "$#,##0") 
			
			VAR Budget = FORMAT(BudgetValue, "$#,##0") 
			
			  
			
			-- Calculate % change (variance) 
			
			VAR ChangePct = DIVIDE(ActualValue - BudgetValue, BudgetValue, 0) 
			
			  
			
			-- Arrow based on direction 
			
			VAR Arrow = IF(ChangePct >= 0, "▲", "▼") 
			
			  
			
			-- Format percentage without sign (add manually) 
			
			VAR ChangePctFormatted = FORMAT(ABS(ChangePct), "0.00%") 
			
			  
			
			-- Final string: Actual + Arrow + % change 
			
			RETURN 
			
			    Actual
			```
		lineageTag: 72a0bf7a-f0bb-4089-9b3b-44b0941aa18b

