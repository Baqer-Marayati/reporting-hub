	measure TotalExpensePYTD = ```
			
			VAR SelectedDate = SELECTEDVALUE(FiscalYearSelection[value])  // e.g., "30/06"
			var selectedPeriod = Period[SelectedKPI]
			Var newFS = accountingPeriods[FiscalYearEnd]
			VAR TodayDate=[TodayLocal]
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			VAR LastYear = YEAR(TodayDate)-1
			VAR StartOfLastCalendarYear=DATE(LastYear,1, 1)
			VAR EndOfLastCalendarYTD=DATE(LastYear, MONTH(TodayDate), DAY(TodayDate))
			VAR PreviousFS = DATE(YEAR([TodayLocal])-1, MONTH([FiscalYearStartDate]), DAY([FiscalYearStartDate]))
			VAR EndFS= DATE(YEAR([TodayLocal])-1, MONTH([TodayLocal]), DAY([TodayLocal]))
			VAR ActualStartDate=IF(selectedPeriod=5, StartOfLastCalendarYear, PreviousFS)
			VAR ActualEndDate=IF(selectedPeriod=5, EndOfLastCalendarYTD, EndFS)
			RETURN
			
			        CALCULATE(
			            'generalLedgerEntries'[TotalExpense],
			            DATESBETWEEN(DateTable[Date], ActualStartDate, ActualEndDate)
			        )
			
			```
