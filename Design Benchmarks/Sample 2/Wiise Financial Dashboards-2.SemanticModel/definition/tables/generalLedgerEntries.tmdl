	measure TotalExpenseMTD = ```
			
			 VAR todayDate=[TodayLocal]
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfThisMonth= Date(YEAR(TodayDate), MONTH(TodayDate), 1)
			 RETURN 
			 CALCULATE('generalLedgerEntries'[TotalExpense],DATESBETWEEN('generalLedgerEntries'[postingDate], StartOfThisMonth, todayDate))
