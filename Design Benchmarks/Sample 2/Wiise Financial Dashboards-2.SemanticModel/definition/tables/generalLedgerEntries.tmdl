	column 'Legend Label' =
			
			VAR CurrentYear = YEAR([TodayLocal]) -- Get the current year
			VAR EvaluatedYear = MAX(DateTable[Year]) -- Get the year in the current filter context
			RETURN
			    SWITCH(
			        TRUE(),
			        EvaluatedYear = CurrentYear, "Current Year",       -- Check for "Current Year"
			        EvaluatedYear = CurrentYear - 1, "Previous Year", -- Check for "Previous Year"
			        FORMAT(EvaluatedYear, "General Number")           -- Default: Return year as text
			    )
		lineageTag: 76827466-029c-4427-add0-010985933929
		summarizeBy: none

