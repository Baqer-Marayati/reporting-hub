table generalLedgerEntries
	lineageTag: 4b46c01e-2ad0-439b-b900-39a895b8162a

	measure TotalRevenue = (CALCULATE( SUM('generalLedgerEntries'[amount]), 'generalLedgerEntries'[accountCategory] = "Income")) * -1
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: RevenueMeasures
		lineageTag: b4cb9eb6-d977-45cd-bd7d-7d83afdf0bb2

	measure TotalCostOfGoodsSold = CALCULATE(SUM('generalLedgerEntries'[amount]), 'generalLedgerEntries'[accountCategory] = "Cost of Goods Sold" )
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		displayFolder: CostOfGoodsSold
		lineageTag: f55fb910-a1e1-4930-b102-19cacee8a398

	measure RevenueFiltered =
			
			Switch('Period'[SelectedKPI],
			5, [TotalRevenueYTD],
			4, [TotalRevenueYTD],
			2, [TotalRevenueMTD],
			3, [TotalRevenueQTD],
			1, [TotalRevenueWTD]
			)
		displayFolder: RevenueMeasures
		lineageTag: 3c8475e3-0c35-4131-bf00-814e5a3cd37a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RevenueVariance = ```
			
			Switch('Period'[SelectedKPI],
			5, 
			VAR percentChange = If([TotalRevenuePYTD] = 0 && [TotalRevenueYTD] > 0, 1, DIVIDE(([TotalRevenueYTD] - [TotalRevenuePYTD]), [TotalRevenuePYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--", arrow & " " & FORMAT(ABS(percentChange), "0%")),
			4, 
			VAR percentChange = If([TotalRevenuePYTD] = 0 && [TotalRevenueYTD] > 0, 1, DIVIDE(([TotalRevenueYTD] - [TotalRevenuePYTD]), [TotalRevenuePYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--", arrow & " " & FORMAT(ABS(percentChange), "0%")),
			3,  
			VAR percentChange = If([TotalRevenue_PQTD] = 0 && [TotalRevenueQTD] > 0, 1, DIVIDE(([TotalRevenueQTD] - [TotalRevenue_PQTD]), [TotalRevenue_PQTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--", arrow & " " & FORMAT(ABS(percentChange), "0%")),
			2,  
			VAR percentChange = If([TotalRevenue_PMTD] = 0 && [TotalRevenueMTD] > 0, 1, DIVIDE(([TotalRevenueMTD] - [TotalRevenue_PMTD]), [TotalRevenue_PMTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--", arrow & " " & FORMAT(ABS(percentChange), "0%")),
			1,  
			VAR percentChange = If([TotalRevenue_PWTD] = 0 && [TotalRevenueWTD] > 0, 1, DIVIDE(([TotalRevenueWTD] - [TotalRevenue_PWTD]), [TotalRevenue_PWTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--", arrow & " " & FORMAT(ABS(percentChange), "0%"))
			)
			```
		displayFolder: RevenueMeasures
		lineageTag: 797d55fe-06f9-4fd0-ba89-e38090186f7d

	measure TotalExpense = CALCULATE(SUM('generalLedgerEntries'[amount]), 'generalLedgerEntries'[accountCategory] = "Expense"  )
		displayFolder: ExpenseMeasures
		lineageTag: e2f2bac9-892d-49c8-b395-06bf8552c00c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenue_PMTD =
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR CurrentDay = DAY(TodayDate)
			VAR CurrentMonth = MONTH(TodayDate)
			VAR CurrentYear = YEAR(TodayDate)
			
			VAR PrevMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PrevYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			
			VAR StartDate = DATE(PrevYear, PrevMonth, 1)
			VAR EndDate = DATE(PrevYear, PrevMonth, CurrentDay)
			
			RETURN
			    CALCULATE(
			        generalLedgerEntries[TotalRevenue],
			       generalLedgerEntries[postingDate] >= StartDate,
			        generalLedgerEntries[postingDate] <= EndDate
			    )
		displayFolder: RevenueMeasures
		lineageTag: ffda4e07-aaac-4bf7-8638-bac968606aca

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenueQTD =
			
			VAR todayDate=[TodayLocal]
			VAR selectedPeriod = Period[SelectedKPI]
			 VAR CurrQuarter = QUARTER(TodayDate)
			VAR YearWiiseQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR startOfQuarterDate = IF(selectedPeriod=5, YearWiiseQuarter, [FiscalQuarterStartDate])
			RETURN
			CALCULATE (
			        'generalLedgerEntries'[TotalRevenue],
			        DATESBETWEEN (
			            'generalLedgerEntries'[postingDate],
			           startOfQuarterDate,
			            [TodayLocal]
			        )
			    )
		displayFolder: RevenueMeasures
		lineageTag: 06ce903c-38e1-4d15-a2ae-5832d3bcbe8d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenueWTD = ```
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			RETURN 
			CALCULATE(
			    SUM('generalLedgerEntries'[amount]),
			    FILTER(
			        'generalLedgerEntries',
			        WEEKNUM('generalLedgerEntries'[postingDate], 2) = WEEKNUM(TodayDate, 2) &&
			        YEAR('generalLedgerEntries'[postingDate]) = YEAR(TodayDate) &&
			        'generalLedgerEntries'[postingDate] <= TodayDate &&
			        'generalLedgerEntries'[accountcategory] = "Income"
			    )
			)*-1
			```
		displayFolder: RevenueMeasures
		lineageTag: f94cd99f-ac1b-4f8a-bc29-5f9eb74c6062

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenueMTD =
			
			VAR todayDate=[TodayLocal]
			VAR StartOfWeek = TodayDate - WEEKDAY(TodayDate, 2) + 1
			VAR StartOfThisMonth= Date(YEAR(TodayDate), MONTH(TodayDate), 1)
			 RETURN CALCULATE('generalLedgerEntries'[TotalRevenue],DATESBETWEEN('generalLedgerEntries'[postingDate],StartOfThisMonth, todayDate ))
		displayFolder: RevenueMeasures
		lineageTag: f622d697-8c78-4e69-a382-e2836142b4b4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenue_PQTD = ```
			
			VAR TodayDate=[TodayLocal]
			var selectedPeriod = Period[SelectedKPI]
			Var newFS = accountingPeriods[FiscalYearEnd]
			
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfPrevQuarter = EDATE(StartOfThisQuarter, -3)
			
			
			
			VAR EndOfPrevQTD=EDATE([TodayLocal], -3)
			
			
			RETURN 
			CALCULATE(
			    generalLedgerEntries[TotalRevenue],
			    DATESBETWEEN (
			            'generalLedgerEntries'[postingDate],
			            StartOfPrevQuarter,
			            EndOFPrevQTD
			        )
			)
			```
		displayFolder: RevenueMeasures
		lineageTag: d01c00ea-26fe-40e6-b4de-98030f858667

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenuePYTD =
			
			VAR SelectedDate = SELECTEDVALUE(FiscalYearSelection[value])  // e.g., "30/06"
			var selectedPeriod = Period[SelectedKPI]
			Var newFS = accountingPeriods[FiscalYearEnd]
			VAR TodayDate=[TodayLocal]
			VAR YearStartDate =DATE(Year(TodayDate), 1,1)
			VAR LastYear = YEAR(TodayDate)-1
			VAR StartOfLastCalendarYear=DATE(LastYear,1, 1)
			VAR EndOfLastCalendarYTD=DATE(LastYear, MONTH(TodayDate), DAY(TodayDate))
			VAR PreviousFS = DATE(YEAR([TodayLocal])-1, MONTH([FiscalYearStartDate]), DAY([FiscalYearStartDate]))
			VAR EndFS= DATE(YEAR([TodayLocal])-1, MONTH([TodayLocal]), DAY([TodayLocal]))
			VAR ActualStartDate=IF(selectedPeriod=5, StartOfLastCalendarYear, PreviousFS)
			VAR ActualEndDate=IF(selectedPeriod=5, EndOfLastCalendarYTD, EndFS)
			RETURN
			CALCULATE (
			        'generalLedgerEntries'[TotalRevenue],
			        DATESBETWEEN (
			            'generalLedgerEntries'[postingDate],
			            ActualStartDate,
			            ActualEndDate
			        )
			    )
		displayFolder: RevenueMeasures
		lineageTag: 065a6353-b265-44f9-a8de-f0f5c06cb7a7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalRevenue_PWTD =
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			VAR WeekdayToday = WEEKDAY(TodayDate, 2)  -- Monday = 1
			
			VAR StartDate = TodayDate - WeekdayToday - 6
			VAR EndDate = StartDate + WeekdayToday - 1
			
			RETURN
			    CALCULATE(
			        generalLedgerEntries[TotalRevenue],
			        FILTER(
			            'DateTable',
			            'DateTable'[Date] >= StartDate && 'DateTable'[Date] <= EndDate
			        )
			    )
		displayFolder: RevenueMeasures
		lineageTag: 0c51a006-ad45-4b4b-9b47-e3ad5ffe8db6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

