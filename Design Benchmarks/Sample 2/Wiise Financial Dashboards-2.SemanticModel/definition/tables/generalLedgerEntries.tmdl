	measure TotalCostOFGoodsSoldYTD = ```
			
			var selectedPeriod = Period[SelectedKPI]
			
			 
			
			VAR startOfFs= If (selectedPeriod =5, DATE(Year([TodayLocal]), 1,1), [FiscalYearStartDate])
			RETURN
			
			 CALCULATE('generalLedgerEntries'[TotalCostOFGoodsSold], DATESBETWEEN('generalLedgerEntries'[postingDate], startOfFs, [TodayLocal]))
			    
