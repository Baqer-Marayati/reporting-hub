			VAR EndOfLastCalendarYTD=DATE(LastYear, MONTH(TodayDate), DAY(TodayDate))
			VAR PreviousFS = DATE(YEAR([TodayLocal])-1, MONTH([FiscalYearStartDate]), DAY([FiscalYearStartDate]))
