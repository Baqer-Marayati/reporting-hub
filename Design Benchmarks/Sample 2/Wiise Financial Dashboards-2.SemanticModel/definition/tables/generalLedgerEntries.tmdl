	measure TotalCostOFGoodsSoldQTD =
			
			VAR todayDate=[TodayLocal]
			VAR selectedPeriod = Period[SelectedKPI]
			 VAR CurrQuarter = QUARTER(TodayDate)
			VAR YearWiiseQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR startOfQuarterDate = IF(selectedPeriod=5, YearWiiseQuarter, [FiscalQuarterStartDate])
