		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalCostOFGoodsSoldWTD =
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			RETURN CALCULATE(
			    SUM('generalLedgerEntries'[amount]),
			    FILTER(
			        generalLedgerEntries,
			        WEEKNUM('generalLedgerEntries'[postingDate], 2) = WEEKNUM(TodayDate, 2) &&  -- Same week
			        YEAR('generalLedgerEntries'[postingDate]) = YEAR(TodayDate) &&              -- Same year
			        'generalLedgerEntries'[postingDate] <= TodayDate &&                         -- Up to today
			        'generalLedgerEntries'[accountcategory] = "Cost of Goods Sold"            -- COGS only
			    )
			)
