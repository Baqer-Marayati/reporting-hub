		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalExpenseWTD = ```
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			RETURN
			CALCULATE(
			    SUM('generalLedgerEntries'[amount]),
			    FILTER(
			        generalLedgerEntries,
			        WEEKNUM('generalLedgerEntries'[postingDate], 2) = WEEKNUM(TodayDate, 2) &&  -- Same week
			        YEAR('generalLedgerEntries'[postingDate]) = YEAR(TodayDate) &&              -- Same year
			        'generalLedgerEntries'[postingDate] <= TodayDate &&                         -- Up to today
			        'generalLedgerEntries'[accountcategory] = "Expense"            -- COGS only
			    )
			)
			
			```
		displayFolder: ExpenseMeasures
		lineageTag: e3302022-8233-44b8-8171-dab0fb187ad7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalExpenseYTD = ```
			
			var selectedPeriod = Period[SelectedKPI]
			
			 
			
			VAR startOfFs= If (selectedPeriod =5, DATE(Year([TodayLocal]), 1,1), [FiscalYearStartDate])
			RETURN
			 CALCULATE('generalLedgerEntries'[TotalExpense], DATESBETWEEN('generalLedgerEntries'[postingDate], startOfFs, [TodayLocal]))
			    
			    
			```
		displayFolder: ExpenseMeasures
		lineageTag: e532ca48-5eb8-47b2-8b66-5e754591c96a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ExpenseVariance = ```
			
			Switch('Period'[SelectedKPI],
			5, 
			VAR percentChange = If([TotalExpensePYTD] = 0 && [TotalExpenseYTD] > 0, 1, DIVIDE(([TotalExpenseYTD] - [TotalExpensePYTD]), [TotalExpensePYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			4, 
			VAR percentChange = If([TotalExpensePYTD] = 0 && [TotalExpenseYTD] > 0, 1, DIVIDE(([TotalExpenseYTD] - [TotalExpensePYTD]), [TotalExpensePYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			3,  
			VAR percentChange = If([TotalExpense_PQTD] = 0 && [TotalExpenseQTD] > 0, 1, DIVIDE(([TotalExpenseQTD] - [TotalExpense_PQTD]), [TotalExpense_PQTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			2,  
			VAR percentChange = If([TotalExpense_PMTD] = 0 && [TotalExpenseMTD] > 0, 1, DIVIDE(([TotalExpenseMTD] - [TotalExpense_PMTD]), [TotalExpense_PMTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			1,  
			VAR percentChange = If([TotalExpense_PWTD] = 0 && [TotalExpenseWTD] > 0, 1, DIVIDE(([TotalExpenseWTD] - [TotalExpense_PWTD]), [TotalExpense_PWTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")))
			```
		displayFolder: ExpenseMeasures
		lineageTag: c3ac4028-4658-4bbd-ba44-77f2ed14cc9d

	measure ExpenseFiltered =
			
