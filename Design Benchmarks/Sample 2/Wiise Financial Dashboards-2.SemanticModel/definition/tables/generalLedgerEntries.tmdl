	measure PercentCOGSVarianceColorFormat = ```
			
			VAR ValueNum = [CostOfGoodsSoldVarianceNumeric]
			RETURN 
			       SWITCH(
			        TRUE(),
			        ValueNum > 0, "#B61335",     -- Red
			        ValueNum = 0, "#818285",     -- Black
			        ValueNum < 0, "#056D4D"      -- Green
			    )
