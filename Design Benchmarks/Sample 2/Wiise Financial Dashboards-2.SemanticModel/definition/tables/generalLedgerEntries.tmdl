	measure DebugTotalRevenueYTD = ```
			
			
			VAR TodayDate=[TodayLocal]
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfPrevQuarter = EDATE(StartOfThisQuarter, -3)
			VAR TEST=EDATE([TodayLocal], -3)
			VAR EndOfPrevQuarter = EOMONTH(StartOfPrevQuarter, 3)
			VAR DayofMonth=DAY(TodayDate)
			VAR EndOFPrevQTD =IF(DayofMonth >Day(EndOfPrevQuarter), EndOfPrevQuarter, StartOfPrevQuarter+DayofMonth-1)
			
			RETURN TEST
			
			```
		formatString: General Date
		displayFolder: RevenueMeasures
		lineageTag: b6a4a609-3f1a-41af-870c-093b890b8ea5

	measure ActualSpend = ```
			
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			VAR Result =           
			    CALCULATE(
			        SUM(generalLedgerEntries[amount]),
			        FILTER(
			            generalLedgerEntries,
			            generalLedgerEntries[accountCategory] = "Expense" && generalLedgerEntries[accountType] = "Posting" && generalLedgerEntries[incomeBalance] = "Income Statement"
			        ),
			        FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 3f2f67d8-f71f-444b-ab6d-8d9b37eada75

	measure ActualSpendDynamic = ```
			
			//Get value of dimension code slicer
			VAR DimSelected = SELECTEDVALUE(DimensionCodeTable[dimensionCodeNumberName]) 
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			// Get value of dimension code no.  - either globalDimension1 or globalDimension2
			VAR DimNoSelected =  
			    FIRSTNONBLANK(
			        CALCULATETABLE(
			            VALUES(DimensionCodeTable[dimensionCodeNo]),
			            DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			        ),
			        1
			    )
			
			VAR DimensionCodesToFilter = 
			    CALCULATETABLE(
			        VALUES(DimensionCodeTable[dimensionCode]),
			        DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			    )
			
			VAR Result =           
			    CALCULATE(
			        SUM(generalLedgerEntries[amount]),
			        FILTER(
			            generalLedgerEntries,
			            generalLedgerEntries[accountCategory] = "Expense" 
			            && generalLedgerEntries[accountType] = "Posting" 
			            && generalLedgerEntries[incomeBalance] = "Income Statement"
			            && IF(
			                DimNoSelected = "shortcutDimension1Code",
			                generalLedgerEntries[globalDimension1Code] IN DimensionCodesToFilter,
			                IF(
			                    DimNoSelected = "shortcutDimension2Code",
			                    generalLedgerEntries[globalDimension2Code] IN DimensionCodesToFilter,
			                    TRUE()
			                )
			            )
			        ),
			      FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			
			```
		lineageTag: 0cb7fd00-16c3-4e52-a222-2e172d707649

		annotation PBI_FormatHint = {"isGeneralNumber":true}

