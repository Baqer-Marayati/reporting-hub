		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalCostOFGoodsSold_PQTD = ```
			
			
			
			VAR TodayDate=[TodayLocal]
			var selectedPeriod = Period[SelectedKPI]
			Var newFS = accountingPeriods[FiscalYearEnd]
			
			VAR CurrQuarter = QUARTER(TodayDate)
			VAR StartOfThisQuarter = DATE(YEAR(TodayDate), (CurrQuarter - 1) * 3 + 1, 1)
			VAR StartOfPrevQuarter = EDATE(StartOfThisQuarter, -3)
			VAR EndOfPrevQTD=EDATE([TodayLocal], -3)
			
			
			RETURN 
			CALCULATE(
			    [TotalCostOFGoodsSold], -- Replace with your measure or column
			    DATESBETWEEN('DateTable'[Date], StartOfPrevQuarter, EndOfPrevQTD)
			)
