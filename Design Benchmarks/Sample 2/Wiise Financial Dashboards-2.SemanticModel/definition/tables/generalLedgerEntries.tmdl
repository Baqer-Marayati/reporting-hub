	measure Budgetpercent = ```
			
			Switch('Period'[SelectedKPI],
			5, 
			VAR percentChange = If([BudgetYTD] = 0, 100, DIVIDE(([grossProfitYTD] - [BudgetYTD]), [BudgetYTD]))
			Var per = IF([BudgetYTD]=0, percentChange, (percentChange * 100) + 100)
			RETURN
			FORMAT(per, "0.00") & "%",
			4, 
			VAR percentChange = If([BudgetYTD] = 0, 100, DIVIDE(([grossProfitYTD] - [BudgetYTD]), [BudgetYTD]))
			Var per = IF([BudgetYTD]=0, percentChange,(percentChange * 100) + 100)
			RETURN
			FORMAT(per, "0.00") & "%",
			3,  
			VAR percentChange = If([BudgetQTD] = 0, 100,DIVIDE(([grossProfitQTD] - [BudgetQTD]), [BudgetQTD]))
			Var per = IF([BudgetQTD]=0, percentChange,(percentChange * 100) + 100)
			RETURN
			FORMAT(per, "0.00") & "%",
			2,  
			VAR percentChange = If([BudgetMTD] = 0 , 100, DIVIDE(([grossProfitMTD] - [BudgetMTD]), [BudgetMTD]))
			Var per = IF([BudgetMTD]=0, percentChange,(percentChange * 100) + 100)
			RETURN
			FORMAT(per, "0.00") & "%",
			1,  
			VAR percentChange = If([BudgetWTD] = 0, 100, DIVIDE(([grossProfitWTD] - [BudgetWTD]), [BudgetWTD]))
			Var per = IF([BudgetWTD]=0, percentChange,(percentChange * 100) + 100)
			RETURN
			FORMAT(per, "0.00") & "%"
			)
			```
