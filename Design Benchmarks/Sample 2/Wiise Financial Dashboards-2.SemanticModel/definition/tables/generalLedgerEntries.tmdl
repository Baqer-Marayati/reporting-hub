	measure CostOfGoodsSoldVariance = ```
			
			Switch('Period'[SelectedKPI],
			5, 
			VAR percentChange = If([TotalCostOFGoodsSold_PYTD] = 0 && [TotalCostOFGoodsSoldYTD] > 0, 1, DIVIDE(([TotalCostOFGoodsSoldYTD] - [TotalCostOFGoodsSold_PYTD]), [TotalCostOFGoodsSold_PYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			4, 
			VAR percentChange = If([TotalCostOFGoodsSold_PYTD] = 0 && [TotalCostOFGoodsSoldYTD] > 0, 1, DIVIDE(([TotalCostOFGoodsSoldYTD] - [TotalCostOFGoodsSold_PYTD]), [TotalCostOFGoodsSold_PYTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			3,  
			VAR percentChange = If([TotalCostOFGoodsSold_PQTD] = 0 && [TotalCostOFGoodsSoldQTD] > 0, 1, DIVIDE(([TotalCostOFGoodsSoldQTD] - [TotalCostOFGoodsSold_PQTD]), [TotalCostOFGoodsSold_PQTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			2,  
			VAR percentChange = If([TotalCostOFGoodsSold_PMTD] = 0 && [TotalCostOFGoodsSoldMTD] > 0, 1, DIVIDE(([TotalCostOFGoodsSoldMTD] - [TotalCostOFGoodsSold_PMTD]), [TotalCostOFGoodsSold_PMTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%")),
			1,  
			VAR percentChange = If([TotalCostOFGoodsSold_PWTD] = 0 && [TotalCostOFGoodsSoldWTD] > 0, 1, DIVIDE(([TotalCostOFGoodsSoldWTD] - [TotalCostOFGoodsSold_PWTD]), [TotalCostOFGoodsSold_PWTD]))
			Var arrow = If(percentChange > 0, UNICHAR(11014), UNICHAR(11015)) 
			RETURN
			IF (percentChange = 0,"--",arrow & " " & FORMAT(ABS(percentChange), "0%"))
			)
			```
