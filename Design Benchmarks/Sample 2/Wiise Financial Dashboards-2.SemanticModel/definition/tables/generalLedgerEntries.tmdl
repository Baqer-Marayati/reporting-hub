			percentChange,
			4, 
			VAR percentChange = If([TotalRevenuePYTD] = 0 && [TotalRevenueYTD] > 0, 1, DIVIDE(([TotalRevenueYTD] - [TotalRevenuePYTD]), [TotalRevenuePYTD]))
			RETURN
			percentChange,
			3,  
			VAR percentChange = If([TotalRevenue_PQTD] = 0 && [TotalRevenueQTD] > 0, 1, DIVIDE(([TotalRevenueQTD] - [TotalRevenue_PQTD]), [TotalRevenue_PQTD]))
			RETURN
			percentChange,
			2,  
			VAR percentChange = If([TotalRevenue_PMTD] = 0 && [TotalRevenueMTD] > 0, 1, DIVIDE(([TotalRevenueMTD] - [TotalRevenue_PMTD]), [TotalRevenue_PMTD]))
			RETURN
			percentChange,
			1,  
			VAR percentChange = If([TotalRevenue_PWTD] = 0 && [TotalRevenueWTD] > 0, 1, DIVIDE(([TotalRevenueWTD] - [TotalRevenue_PWTD]), [TotalRevenue_PWTD]))
			RETURN
			percentChange
			)
			```
		displayFolder: RevenueMeasures
		lineageTag: bd9718d1-63f1-4483-9916-92e9e7564339

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ExpenseVarianceNumeric = ```
			
