table accountingPeriods
	lineageTag: f49a5117-de26-4078-bc37-97fd58794437

	measure FiscalYearStartDate =
			
			CALCULATE(
			    MINX(
			        FILTER(
			            accountingPeriods,
			            accountingPeriods[newFiscalYear] = TRUE() &&
			            YEAR(accountingPeriods[startingDate]) = YEAR([TodayLocal])
			        ),
			        accountingPeriods[startingDate]
			    )
			)
		formatString: General Date
		lineageTag: b795ad4d-4b8b-48fb-aa21-141026414138

	measure FiscalYearEnd = FORMAT(EOMONTH(accountingPeriods[FiscalYearStartDate], -1), "dd/MM")
		lineageTag: 303bccd5-824c-4c36-9329-ee7cf53cf734

	measure FiscalYearDetails = ```
			
			Var FiscalEnd = EOMONTH(accountingPeriods[FiscalYearStartDate], -1)
			RETURN
			FORMAT([FiscalYearStartDate], "MMM") & "–" & FORMAT(FiscalEnd, "MMM")
			
			```
		lineageTag: 2852a853-aded-4086-9bad-0a0c862b2ce2

	measure FiscalQuarterStartDate =
			
			
			VAR localToday = [TodayLocal]
			VAR newFS= accountingPeriods[FiscalYearEnd]
			VAR fyEndMonth =VALUE(RIGHT(newFS, 2))
			
			
			VAR shiftedMonth = MOD ( MONTH ( localToday ) - fyEndMonth - 1, 12 ) + 1
			VAR quarterNumber = INT ( ( shiftedMonth - 1 ) / 3 ) + 1
			VAR quarterStartMonth = ( quarterNumber - 1 ) * 3 + 1 + fyEndMonth
			VAR correctedMonth = IF ( quarterStartMonth > 12, quarterStartMonth - 12, quarterStartMonth )
			VAR correctedYear = YEAR ( localToday ) - IF ( quarterStartMonth > 12, 1, 0 )
			RETURN DATE ( correctedYear, correctedMonth, 1 )
		formatString: General Date
		lineageTag: 9a8e625b-6a93-4f1f-a1d0-b666796a9146

