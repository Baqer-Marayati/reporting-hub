	column IsWeekend
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: aa0332dc-0d18-4c72-acb9-24473c4dc5e4
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsWeekend]

		annotation SummarizationSetBy = Automatic

	partition DateTableCommitment = calculated
		mode: import
		source = ```
				
				VAR StartDate = 
				    COALESCE(
				        MINX(
				            UNION(
				                SELECTCOLUMNS(generalLedgerEntries, "Date", [postingDate]),
				                SELECTCOLUMNS(glBudgetEntries, "Date", [date]),
				                SELECTCOLUMNS(purchaseLines, "Date", [postingDate])
				            ),
				            [Date]
				        ),
				        DATE(2020, 1, 1) -- Default start date
				    )
				
				VAR EndDate = 
				    COALESCE(
				        MAXX(
				            UNION(
				                SELECTCOLUMNS(generalLedgerEntries, "Date", [postingDate]),
				                SELECTCOLUMNS(glBudgetEntries, "Date", [date]),
				                SELECTCOLUMNS(purchaseLines, "Date", [postingDate])
				            ),
				            [Date]
				        ),
				        [TodayLocal] -- Default end date
				    )
				
				RETURN
				ADDCOLUMNS(
				    CALENDAR(StartDate, EndDate),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Month", MONTH([Date]),
				    "Month Name", FORMAT([Date], "MMMM"),
				    "Month Name Short", FORMAT([Date], "MMM YY"),
				    "Day", DAY([Date]),
				    "Day Name", FORMAT([Date], "dddd"),
				    "Weekday Number", WEEKDAY([Date], 2),
				    "IsWeekend", IF(WEEKDAY([Date], 2) > 5, TRUE(), FALSE())
				)
				```

	annotation PBI_Id = fcbf246b66a74bbba8267666d170a85e

