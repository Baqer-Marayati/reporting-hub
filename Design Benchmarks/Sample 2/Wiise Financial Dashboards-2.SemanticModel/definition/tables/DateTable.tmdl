	column IsWeekend
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: a8b8bc6f-7e2c-4d92-8b54-aa2da9fa72e2
		summarizeBy: none
		isNameInferred
		sourceColumn: [IsWeekend]

		annotation SummarizationSetBy = Automatic

	column IsPreviousMonthToDate =
			
			// VAR TodayDate = TODAY()
			VAR TodayDate=[TodayLocal]
			
			VAR CurrentDay = DAY(TodayDate)
			VAR CurrentMonth = MONTH(TodayDate)
			VAR CurrentYear = YEAR(TodayDate)
			
			VAR PrevMonth = IF(CurrentMonth = 1, 12, CurrentMonth - 1)
			VAR PrevYear = IF(CurrentMonth = 1, CurrentYear - 1, CurrentYear)
			
			VAR StartDate = DATE(PrevYear, PrevMonth, 1)
			VAR EndDate = DATE(PrevYear, PrevMonth, CurrentDay)
			
			RETURN
			    IF(
			        'DateTable'[Date] >= StartDate && 'DateTable'[Date] <= EndDate,
			        TRUE(),
			        FALSE()
			    )
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 3baa20a1-7038-43e3-856d-5872c8dc46f0
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Month Name Short'
		lineageTag: e38a9717-bb68-4cf9-985b-144c9483bd45
		summarizeBy: none
		isNameInferred
		sourceColumn: [Month Name Short]
		sortByColumn: MonthsortOrder

		annotation SummarizationSetBy = Automatic

	column MonthsortOrder = YEAR([Date]) *100 + Month([Date])
		formatString: 0
		lineageTag: 88a55484-716f-4b48-95bc-dbe3d0cb0cc6
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN(generalLedgerEntries[postingDate]), -- Dynamic start date based on the earliest date in your Sales table
				        MAX(generalLedgerEntries[postingDate])  -- Dynamic end date based on the latest date in your Sales table
				    ),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Month", MONTH([Date]), -- Numeric month (1 = January, 2 = February)
				    "Month Name", FORMAT([Date], "MMMM"), -- Full name of the month (January, February, etc.)
				    "Month Name Short", FORMAT([Date], "MMM YY"), -- Full name of the month (January, February, etc.)
				    "Day", DAY([Date]),
				    "Day Name", FORMAT([Date], "dddd"), -- Day name (e.g., Monday, Tuesday, etc.)
				    "Weekday Number", WEEKDAY([Date], 2), -- 2 makes Monday = 1 and Sunday = 7
				    "IsWeekend", IF(WEEKDAY([Date], 2) > 5, TRUE(), FALSE()) -- TRUE for Saturday/Sunday, FALSE otherwise
				)

	annotation PBI_Id = 56cab8a3af2342068588a2711634dcff

