	measure 'Closing AP' =
			
			VAR EOfMonth = MINX(ENDOFMONTH(DateTableAccountPayables[Date]),DateTableAccountPayables[Date])
			RETURN
			CALCULATE(
			    SUM(vendorLedgerEntries[remainingAmount]) * -1,
			    vendorLedgerEntries[postingDate] <= EOfMonth
			)
