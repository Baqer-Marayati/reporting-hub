		lineageTag: 3c8e5f76-0a02-4495-a979-8e5408d27b26

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Accountpayables_ageingReport_new = ```
			
			VAR TodayDate = [TodayLocal]
			VAR SelectedBucket = SELECTEDVALUE(DueCategorySortTable[DueCategory])
			RETURN
			SWITCH(
			    SelectedBucket,
			    "Overdue",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] < TodayDate) * -1,
			    "Due today",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] = TodayDate) * -1,
			    "Due next 30 days",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] > TodayDate && vendorLedgerEntries[dueDate] <= TodayDate + 30) * -1,
			    "Due next 60 days",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] > TodayDate + 30 && vendorLedgerEntries[dueDate] <= TodayDate + 60) * -1,
			    "Due next 90 days",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] > TodayDate + 60 && vendorLedgerEntries[dueDate] <= TodayDate + 90) * -1,
			    "Due next >90 days",
			        CALCULATE(SUM('vendorLedgerEntries'[remainingAmount]), vendorLedgerEntries[open] = TRUE(), vendorLedgerEntries[dueDate] > TodayDate + 90) * -1
			)
			
			```
		displayFolder: AccountPayableMeasures
		lineageTag: 19d53165-bfb2-44d0-944e-a1f3c91a9db5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Accountpayables_overdue_funnel =
			
			Var Today = [TodayLocal]
			RETURN
			CALCULATE(
			    SUM('vendorLedgerEntries'[remainingAmount]),
			    vendorLedgerEntries[open] = true,
			    vendorLedgerEntries[dueDate] <= Today
			)*-1
		displayFolder: AccountPayableMeasures
		lineageTag: bdd60521-de54-4ebf-a5aa-f28e1d2240eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Payable_Turnover_Ratio_value = ```
			
			VAR sOfMonth = Date(Year([TodayLocal]), Month([TodayLocal]),1)
			var EOfMonth = EOMONTH([TodayLocal], 0)
			var totalCags = CALCULATE(
			    SUM(generalLedgerEntries[amount]),
			    generalLedgerEntries[accountCategory] = "Cost of Goods Sold",
			    DATESBETWEEN(generalLedgerEntries[postingDate], sOfMonth, EOfMonth)
			)
			
			var openingAP = 
			CALCULATE(
			    SUM(vendorLedgerEntries[remainingAmount]) * -1,
			        vendorLedgerEntries[open] = true &&
			        vendorLedgerEntries[postingDate] <= sOfMonth
			)
			
			var closingAP = CALCULATE(
			    SUM(vendorLedgerEntries[remainingAmount]) * -1,
			    vendorLedgerEntries[postingDate] <= EOfMonth
			)
			
			var averageAP = 
			DIVIDE(
			    openingAP + closingAP,
			    2
			)
			
			var val = 
			DIVIDE(
			    totalCags,averageAP
			)
			Return 
			"Payable turnover ratio " & FORMAT(val,"0.00")
			```
		displayFolder: AccountPayableMeasures
		lineageTag: 5f631199-5e5b-4c19-98ee-94c683a229b8

