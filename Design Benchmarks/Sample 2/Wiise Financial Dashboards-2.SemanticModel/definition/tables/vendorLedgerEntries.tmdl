			 Var startOfCurrentMonth = DATE(YEAR([TodayLocal]), MONTH([TodayLocal]), 1)
			 Var currentDate = [TodayLocal]
			 RETURN
			 CALCULATE(SUM('generalLedgerEntries'[amount]), 'generalLedgerEntries'[accountCategory] = "Cost of Goods Sold",
			 'generalLedgerEntries'[documentType] = "Invoice",
			 DATESBETWEEN( generalLedgerEntries[postingDate], startOfCurrentMonth,currentDate))
			```
