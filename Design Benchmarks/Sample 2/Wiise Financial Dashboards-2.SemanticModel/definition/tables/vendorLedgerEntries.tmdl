table vendorLedgerEntries
	lineageTag: c651065b-5b10-48e1-ad34-09a19248ce05

	measure Accountpayables = ```
			
			 Var beginningOfTime = Min(vendorLedgerEntries[postingDate])
			 Var currentDate = [TodayLocal]
			 RETURN
			CALCULATE(
			    SUM('vendorLedgerEntries'[remainingAmount]),
			    vendorLedgerEntries[open] = true,
			    DATESBETWEEN(vendorLedgerEntries[postingDate], beginningOfTime,currentDate)
			)*-1
			```
		displayFolder: AccountPayableMeasures
		lineageTag: d4bd2163-8636-406c-beb9-1447ad5e2b80

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'TodayLocal 1' = ```
			
			VAR timeZone = CALCULATE(SELECTEDVALUE(userpersonalizations[timeZoneDisplayName]))
			
			
			// Find position of "+" and "-"
			VAR posPlus = FIND("+", timeZone, 1, 0)
			VAR posMinus = FIND("-", timeZone, 1, 0)
			
			// Determine sign and position
			VAR sign =
			    IF(posPlus > 0, 1,
			        IF(posMinus > 0, -1,
			            0 // fallback if neither found
			        )
			    )
			
			VAR posSign = IF(sign = 1, posPlus, posMinus)
			
			// Extract the number after the sign until ":"
			VAR offsetText =
			    MID(
			        timeZone,
			        posSign + 1,
			        FIND(":", timeZone, posSign, LEN(timeZone)) - posSign - 1
			    )
			
			VAR offsetHours = sign * VALUE(offsetText)
			
			// Calculate local time by adding offsetHours to UTCNOW()
			VAR localTime = UTCNOW() +  (offsetHours / 24)
			VAR localDate = DATE(YEAR(localTime), MONTH(localTime), DAY(localTime))
			
			RETURN
			   COALESCE(localDate, TODAY())
			
			```
		formatString: General Date
		displayFolder: AccountPayableMeasures
		lineageTag: 4855cb70-e397-45a7-8e3c-80f78d1836c6

