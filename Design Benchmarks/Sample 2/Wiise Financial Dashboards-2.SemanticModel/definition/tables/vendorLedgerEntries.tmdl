	measure CountOfInvoices =
			
			CALCULATE(
			    DISTINCTCOUNT(vendorLedgerEntries[documentNo]),
			    FILTER(
			        vendorLedgerEntries,
			        vendorLedgerEntries[open] = TRUE &&
			        vendorLedgerEntries[documentType] = "Invoice"
			    )
			)
