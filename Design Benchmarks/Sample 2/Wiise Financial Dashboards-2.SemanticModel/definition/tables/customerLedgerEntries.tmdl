	column DueCategory_AR =
			
			Var TodayDate = [TodayLocal]
			VAR DueDate = customerLedgerEntries[dueDate]
			Return
			SWITCH(
			    TRUE(),
			    ISBLANK(DueDate), "No Due Date",
			    DueDate < TodayDate - 90 , "Overdue >90 days",
			    DueDate >= TodayDate - 90 && DueDate < TodayDate - 60, "Overdue 61-90 days",
			    DueDate >= TodayDate - 60 && DueDate < TodayDate - 30, "Overdue 31-60 days",
			   DueDate >= TodayDate - 30 && DueDate < TodayDate, "Overdue 1-30 days",
			    DueDate >= TodayDate && DueDate < TodayDate + 30, "Due next 30 days",
			    DueDate >= TodayDate + 30,"Still on time"
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: 8fe1446c-961b-4bf1-bb3c-bd632918f4f4
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

