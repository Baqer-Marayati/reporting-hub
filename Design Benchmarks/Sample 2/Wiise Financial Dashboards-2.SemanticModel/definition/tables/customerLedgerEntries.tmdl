table customerLedgerEntries
	lineageTag: 764081c2-7450-4a87-905f-e891d4347886

	measure TotalOverdue_AR = ```
			
			 Var beginningOfTime = Min(customerLedgerEntries[dueDate])
			 Var currentDate = [TodayLocal]
			 RETURN
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    vendorLedgerEntries[open] = true,
			    DATESBETWEEN(customerLedgerEntries[dueDate], beginningOfTime,currentDate)
			)
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: 18096c79-e7f1-4077-929e-d5546cb8d481

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure TotalOutstanding_AR = ```
			
			 Var beginningOfTime = Min(customerLedgerEntries[postingDate])
			 Var currentDate = [TodayLocal]
			 RETURN
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    vendorLedgerEntries[open] = true,
			    DATESBETWEEN(customerLedgerEntries[postingDate], beginningOfTime,currentDate)
			)
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: 60cd568a-628a-4d29-9440-b1732eaa8f61

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure PercentageOverdue = ```
			
			IF (
			    [TotalOutstanding_AR] = 0,
			    "--",
			    FORMAT ( DIVIDE ( [TotalOverdue_AR], [TotalOutstanding_AR] ), "0%" )
			)
			
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: 198973ee-b0a0-4b26-883f-bbaa05e25647

	measure TotalCreditSales =
			
			Var TodayDate = [TodayLocal]
			Var today365 = [TodayLocal] - 365
			RETURN
			CALCULATE(Sum(customerLedgerEntries[amount]),
			customerLedgerEntries[paymentMethodCode] <> "CASH",
			DATESBETWEEN(customerLedgerEntries[postingDate], today365, TodayDate)
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: 27887df7-c7ad-4f3e-a235-d9e5b4e21d2a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AccountReceivable_DSO =
			
			Var TodayDate = [TodayLocal]
			RETURN
			CALCULATE(Sum(customerLedgerEntries[remainingAmount]),
			customerLedgerEntries[open]=true,
			DATESBETWEEN(customerLedgerEntries[postingDate], TodayDate -365, TodayDate)
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: b3b2748a-9b0d-4cc0-9cf1-73d0be0aa151

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure DSO = ```
			
			 Var Days = 365
			 RETURN
			 If([TotalCreditSales] = 0, "--", FORMAT(Divide([AccountReceivable_DSO],[TotalCreditSales])*Days,0))
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: 642cea63-8b83-4e3a-b497-4d930d816d48

	measure AccountReceivables_ageingReport_new = ```
			
			VAR TodayDate = [TodayLocal]
			VAR SelectedBucket = SELECTEDVALUE(DueCategorySortTable_AR[DueCategory])
			RETURN
			SWITCH(
			    SelectedBucket,
			    "Overdue >90 days",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] < TodayDate - 90),
			    "Overdue 61-90 days",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] >= TodayDate - 90 && customerLedgerEntries[dueDate] < TodayDate - 60),
			    "Overdue 31-60 days",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] >= TodayDate - 60 && customerLedgerEntries[dueDate] < TodayDate - 30),
			    "Overdue 1-30 days",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] >= TodayDate - 30 && customerLedgerEntries[dueDate] < TodayDate),
			    "Due next 30 days",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] >= TodayDate && customerLedgerEntries[dueDate] < TodayDate + 30),
			    "Still on time",
			        CALCULATE(SUM(customerLedgerEntries[remainingAmount]), customerLedgerEntries[open] = TRUE(), customerLedgerEntries[dueDate] >= TodayDate + 30),
			    0
			)
			
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: f0ba1e9e-3058-4143-a27c-11d55ed6db89

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AccountReceivable_outstanding =
			
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    customerLedgerEntries[open] = true
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: 5ea2b4af-e0e0-44d8-af84-2598bb003c2c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AR_CountOfInvoices = ```
			
			CALCULATE(
			    DISTINCTCOUNT(customerLedgerEntries[documentNo]),
			    FILTER(
			        customerLedgerEntries,
			        customerLedgerEntries[open] = TRUE &&
			        customerLedgerEntries[documentType] = "Invoice"
			    )
			) 
			```
		formatString: 0
		displayFolder: AccountReceivable_Measures
		lineageTag: 4eacff7f-e297-411d-b2dc-e69fab4d9222

	measure AR_InvoiceStatusPercent_Open = ```
			
			 Var tomorrow = [TodayLocal] + 1
			 Var eOfMonth = EOMONTH(tomorrow,0)
			 RETURN
			CALCULATE(
			    DISTINCTCOUNT('customerLedgerEntries'[documentNo]),
			    customerLedgerEntries[open] = true,
			    customerLedgerEntries[documentType] = "Invoice",
			    DATESBETWEEN(customerLedgerEntries[dueDate], tomorrow,eOfMonth)
			)
			```
		formatString: 0
		displayFolder: AccountReceivable_Measures
		lineageTag: 5b834ac0-862a-4ed0-8048-69bb99c60b99

	measure AR_InvoiceStatusPercent_Overdue = ```
			
			 Var startOfCurrentMonth = DATE(YEAR([TodayLocal]), MONTH([TodayLocal]), 1)
			 RETURN
			CALCULATE(
			    DISTINCTCOUNT('customerLedgerEntries'[documentNo]),
			    customerLedgerEntries[open] = true,
			    customerLedgerEntries[documentType] = "Invoice",
			    DATESBETWEEN(customerLedgerEntries[dueDate], startOfCurrentMonth,[TodayLocal])
			)
			```
		formatString: 0
		displayFolder: AccountReceivable_Measures
		lineageTag: 4ecafa74-bbaf-45d3-bea0-38ca9a4dd6c8

	measure AR_InvoiceStatusPercent_Paid = ```
			
			 Var startOfCurrentMonth = DATE(YEAR([TodayLocal]), MONTH([TodayLocal]), 1)
			  Var eOfMonth = EOMONTH([TodayLocal],0)
			
			 RETURN
			CALCULATE(
			    DISTINCTCOUNT('customerLedgerEntries'[documentNo]),
			    customerLedgerEntries[open] = false,
			    customerLedgerEntries[documentType] = "Invoice",
			    DATESBETWEEN(customerLedgerEntries[dueDate], startOfCurrentMonth,eOfMonth)
			)
			```
		formatString: 0
		displayFolder: AccountReceivable_Measures
		lineageTag: beb2ac86-ac90-4f3e-8dc3-10b63b81e49b

	measure AR_totalReceivable_funnel =
			
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    vendorLedgerEntries[open] = true
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: 6e433554-a1b8-4a4f-8588-9d5cdff21fdc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AR_overdue_funnel =
			
			Var Today = [TodayLocal]
			RETURN
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    customerLedgerEntries[open] = true,
			    customerLedgerEntries[dueDate] <= Today
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: cb3fc349-bf88-48be-978c-eab43ba2640a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure AR_notYetDue_funnel =
			
			Var Today = [TodayLocal]
			RETURN
			CALCULATE(
			    SUM('customerLedgerEntries'[remainingAmount]),
			    customerLedgerEntries[open] = true,
			    customerLedgerEntries[dueDate] > Today
			)
		displayFolder: AccountReceivable_Measures
		lineageTag: 9e3cf5dc-96af-4c80-ba01-7399eabe6512

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RTO = ```
			
			VAR sOfMonth = MINX(STARTOFMONTH(DateTableAccountReceivables[Date]),DateTableAccountReceivables[Date])
			VAR EOfMonth = MINX(ENDOFMONTH(DateTableAccountReceivables[Date]),DateTableAccountReceivables[Date])
			Var OpeningAR = CALCULATE(
			    SUM(customerLedgerEntries[remainingAmount]),
			        customerLedgerEntries[open] = true &&
			        customerLedgerEntries[postingDate] < sOfMonth
			)
			
			Var ClosingAR = 
			CALCULATE(
			    SUM(customerLedgerEntries[remainingAmount]),
			     customerLedgerEntries[open] = true &&
			    customerLedgerEntries[postingDate] <= EOfMonth
			)
			
			Var AverageAR = Divide((OpeningAR + ClosingAR),2)
			Var TotalCreditSales = 
			CALCULATE(Sum(customerLedgerEntries[amount]),
			customerLedgerEntries[paymentMethodCode]<>"CASH",
			DATESBETWEEN(customerLedgerEntries[postingDate], sOfMonth, EOfMonth)
			)
			
			Var RTO = If(AverageAR = 0, "--", Divide(TotalCreditSales, AverageAR))
			RETURN 
			RTO
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: 8266ef77-32fe-4be5-b538-5e2edc1a0e27

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RTO_value = ```
			
			VAR sOfMonth = Date(Year([TodayLocal]), Month([TodayLocal]),1)
			var EOfMonth = EOMONTH([TodayLocal], 0)
			Var OpeningAR = CALCULATE(
			    SUM(customerLedgerEntries[remainingAmount]),
			        customerLedgerEntries[open] = true &&
			        customerLedgerEntries[postingDate] < sOfMonth
			)
			
			Var ClosingAR = 
			CALCULATE(
			    SUM(customerLedgerEntries[remainingAmount]),
			     customerLedgerEntries[open] = true &&
			    customerLedgerEntries[postingDate] <= EOfMonth
			)
			
			Var AverageAR = Divide((OpeningAR + ClosingAR),2)
			Var TotalCreditSales = 
			CALCULATE(Sum(customerLedgerEntries[amount]),
			customerLedgerEntries[paymentMethodCode]<>"CASH",
			DATESBETWEEN(customerLedgerEntries[postingDate], sOfMonth, EOfMonth)
			)
			
			Var RTO = If(AverageAR = 0, "--", Divide(TotalCreditSales, AverageAR))
			RETURN 
			"Receivable turnover ratio " & Format(RTO,"0.00")
			```
		displayFolder: AccountReceivable_Measures
		lineageTag: cee8d85a-8ab4-4454-830f-1c2a7f7f022d

