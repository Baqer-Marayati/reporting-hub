table FiscalYearSelection
	lineageTag: 72a7ff9a-6a3b-4bd2-963b-c7eabb09c366

	measure SelectedFiscalYear = MIN('FiscalYearSelection'[value])
		lineageTag: 3400845e-e731-4d8b-81d4-c1cf15eac778

	column fiscalMonth
		formatString: 0
		lineageTag: a2df609d-63d3-42d1-aca5-7c1ead2eb4b6
		summarizeBy: sum
		isNameInferred
		sourceColumn: [fiscalMonth]

