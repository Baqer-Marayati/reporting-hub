	column IsInLast6Months_PTO = ```
			
			VAR TodayDate = [TodayLocal]
			VAR OneYearAgo = EDATE(TodayDate, -6)
			VAR DateVal= DateTableAccountPayables[Date]
			RETURN
			IF(ISBLANK(DateVal), FALSE,
			    DateVal >= OneYearAgo &&
			    DateVal <= TodayDate)
			
			```
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: fc6dd844-e111-468c-bafc-a279e625f551
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column YearMonthNum
		formatString: 0
		lineageTag: eca4b8dc-eabe-4554-b196-c941503df187
		summarizeBy: sum
		isNameInferred
		sourceColumn: [YearMonthNum]

		annotation SummarizationSetBy = Automatic

	partition DateTableAccountPayables = calculated
		mode: import
		source =
				
				VAR MinDateRaw =
				    MINX(
				        UNION(
				            SELECTCOLUMNS(vendorLedgerEntries, "Date", vendorLedgerEntries[postingDate]),
				            SELECTCOLUMNS(generalLedgerEntries, "Date", generalLedgerEntries[postingDate])
				        ),
				        [Date]
				    )
				VAR MaxDateRaw =
				    MAXX(
				        UNION(
				            SELECTCOLUMNS(vendorLedgerEntries, "Date", vendorLedgerEntries[postingDate]),
				            SELECTCOLUMNS(generalLedgerEntries, "Date", generalLedgerEntries[postingDate])
				        ),
				        [Date]
				    )
				VAR MinDate = COALESCE(MinDateRaw, DATE(2000, 1, 1))
				VAR MaxDate = COALESCE(MaxDateRaw, DATE(2000, 1, 2))
				RETURN
				
				ADDCOLUMNS(
				    CALENDAR(
				        MinDate, -- Dynamic start date based on the earliest date in your Sales table
				        MaxDate  -- Dynamic end date based on the latest date in your Sales table
				    ),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Month", MONTH([Date]), -- Numeric month (1 = January, 2 = February)
				    "Month Year", FORMAT([Date], "MMM YY"), -- Numeric month (1 = January, 2 = February)
				    "Month Name", FORMAT([Date], "MMMM"), -- Full name of the month (January, February, etc.)
				    "Month Name Short", FORMAT([Date], "MMM YY"), -- Full name of the month (January, February, etc.)
				    "Day", DAY([Date]),
				    "Day Name", FORMAT([Date], "dddd"), -- Day name (e.g., Monday, Tuesday, etc.)
				    "Weekday Number", WEEKDAY([Date], 2), -- 2 makes Monday = 1 and Sunday = 7
				    "IsWeekend", IF(WEEKDAY([Date], 2) > 5, TRUE(), FALSE()), -- TRUE for Saturday/Sunday, FALSE otherwise
				    "MonthStart", DATE(YEAR([Date]), MONTH([Date]), 1),
				    "MonthEnd", EOMONTH([Date], 0),
				    "YearMonthNum", YEAR([Date]) * 100 + MONTH([Date])
				)

	annotation PBI_Id = 74f540d6ce1c483691989669a0887b43

