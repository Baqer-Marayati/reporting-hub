		sourceColumn: [Global Dimension 2]

		annotation SummarizationSetBy = Automatic

	partition CommitmentDocumentTable = calculated
		mode: import
		source = ```
				
				UNION(
				        SELECTCOLUMNS(
				            //FILTER(purchaseLines, purchaseLines[date] >= [StartDate] && purchaseLines[date] <= [EndDate]),   
				            FILTER(purchaseLines, NOT(ISBLANK(purchaseLines[date])) && purchaseLines[date] >= [StartDate]), 
				            "Number", purchaseLines[DocumentNo],
				            "Type",
				                SWITCH(
				                    TRUE(),
				                    purchaseLines[DocumentType] = "Quote", "Requisition",
				                    purchaseLines[DocumentType] = "Order", "Purchase Order",
				                    purchaseLines[DocumentType] = "Invoice", "Purchase Invoice",
				                    BLANK()
				                ),
				            "Status",
				                SWITCH(
				                    TRUE(),
				                    purchaseLines[DocumentType] = "Quote", "Uncommitted",
				                    purchaseLines[DocumentType] = "Order", "Committed",
				                    purchaseLines[DocumentType] = "Invoice", "Committed",
				                    BLANK()
				                ),
				            "Amount", purchaseLines[amountIncludingVAT],        
				            "Vendor", purchaseLines[buyFromVendorName],
				            "Date", purchaseLines[date],
				            "Account No", purchaseLines[no],
				            "Global Dimension 1", purchaseLines[shortcutDimension1Code],
				            "Global Dimension 2", purchaseLines[shortcutDimension2Code]
				        ),
				        SELECTCOLUMNS(
				            //generalLedgerEntries,
				           //FILTER(generalLedgerEntries, generalLedgerEntries[postingDate] >= [StartDate] && generalLedgerEntries[postingDate] <= [EndDate]),
				           FILTER(generalLedgerEntries, NOT(ISBLANK(generalLedgerEntries[postingDate])) && generalLedgerEntries[postingDate] >= [StartDate]),
				                      
				            "Number", generalLedgerEntries[DocumentNo],
				            "Type",
				                SWITCH(
				                    TRUE(),
				                    generalLedgerEntries[DocumentType] = "Invoice", "Invoice",
				                    BLANK()
				                ),
				            "Status",
				                SWITCH(
				                    TRUE(),
				                    generalLedgerEntries[DocumentType] = "Invoice", "Actual",
				                    BLANK()
				                ),
				                "Amount", generalLedgerEntries[amount],
				                "Vendor", BLANK(),
				                "Date", generalLedgerEntries[postingDate],
				                "Account No", generalLedgerEntries[no],
				                "Global Dimension 1", generalLedgerEntries[globalDimension1Code],
				                "Global Dimension 2", generalLedgerEntries[globalDimension2Code]
				        )
				    )   
				
				```

	annotation PBI_Id = 17c23af30ebc4679bf549d2bea3f76ca

