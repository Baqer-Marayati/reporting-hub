table purchaseLines
	lineageTag: bc200ce4-9ef6-4f88-a5e2-c3bd16577fbd

	measure CommittedPO = ```
			
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			VAR Result =           
			    CALCULATE(
			        SUM(purchaseLines[amountIncludingVAT]),
			        FILTER(
			            purchaseLines,
			            purchaseLines[type] = "G/L Account" && (purchaseLines[documentType] = "Order" || purchaseLines[documentType] = "Invoice")
			        ),
			          FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: b41d6b76-183f-4292-a8ad-0d4d615066a6

	measure CommittedPODynamic = ```
			
			//Get value of dimension code slicer
			VAR DimSelected = SELECTEDVALUE(DimensionCodeTable[dimensionCodeNumberName]) 
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			// Get value of dimension code no  - either globalDimension1 or globalDimension2
			VAR DimNoSelected =  
			    FIRSTNONBLANK(
			        CALCULATETABLE(
			            VALUES(DimensionCodeTable[dimensionCodeNo]),
			            DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			        ),
			        1
			    )
			
			VAR DimensionCodesToFilter = 
			    CALCULATETABLE(
			        VALUES(DimensionCodeTable[dimensionCode]),
			        DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			    )
			
			VAR Result =           
			    CALCULATE(
			        SUM(purchaseLines[amountIncludingVAT]),
			        FILTER(
			            purchaseLines,
			            purchaseLines[type] = "G/L Account" 
			            && (purchaseLines[documentType] = "Order" || purchaseLines[documentType] = "Invoice")
			            && IF(
			                DimNoSelected = "shortcutDimension1Code",
			                purchaseLines[shortcutDimension1Code] IN DimensionCodesToFilter,
			                IF(
			                    DimNoSelected = "shortcutDimension2Code",
			                    purchaseLines[shortcutDimension2Code] IN DimensionCodesToFilter,
			                    TRUE()
			                )
			            )
			        ),
			       FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 8fbe7776-04bc-4c06-bf40-be05010e18ee

	measure UnCommittedPO = ```
			
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			VAR Result =           
			    CALCULATE(
			        SUM(purchaseLines[amountIncludingVAT]),
			        FILTER(
			            purchaseLines,
			            purchaseLines[type] = "G/L Account" && (purchaseLines[documentType] = "Quote" )
			        ),
			         FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 92bef24e-213a-451d-8622-1b74de8438a2

	measure UnCommittedPODynamic = ```
			
			//Get value of dimension code slicer
			VAR DimSelected = SELECTEDVALUE(DimensionCodeTable[dimensionCodeNumberName]) 
			VAR StartDate = [StartDate]
			VAR EndDate = [EndDate]
			
			// Get value of dimension code no  - either globalDimension1 or globalDimension2
			VAR DimNoSelected =  
			    FIRSTNONBLANK(
			        CALCULATETABLE(
			            VALUES(DimensionCodeTable[dimensionCodeNo]),
			            DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			        ),
			        1
			    )
			
			VAR DimensionCodesToFilter = 
			    CALCULATETABLE(
			        VALUES(DimensionCodeTable[dimensionCode]),
			        DimensionCodeTable[dimensionCodeNumberName] = DimSelected
			    )
			
			VAR Result =           
			    CALCULATE(
			        SUM(purchaseLines[amountIncludingVAT]),
			        FILTER(
			            purchaseLines,
			            purchaseLines[type] = "G/L Account" 
			            && purchaseLines[documentType] = "Quote"
			            && IF(
			                DimNoSelected = "shortcutDimension1Code",
			                purchaseLines[shortcutDimension1Code] IN DimensionCodesToFilter,
			                IF(
			                    DimNoSelected = "shortcutDimension2Code",
			                    purchaseLines[shortcutDimension2Code] IN DimensionCodesToFilter,
			                    TRUE()
			                )
			            )
			        ),
			       FILTER(
			            'DateTableCommitment',
			            'DateTableCommitment'[Date] >= StartDate &&
			            'DateTableCommitment'[Date] <= EndDate
			        )
			    )
			    
			RETURN Result
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: e683044f-6fe2-47b2-a611-25c9c748c69d

