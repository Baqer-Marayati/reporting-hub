	partition purchaseLines = m
		mode: import
		source = ```
				let
				    Source = Dynamics365BusinessCentral.ApiContentsWithOptions(null, null, null, null),
				    EnvironmentParam = Table.SelectRows(Source, each Text.Upper([Name]) = Text.Upper(Text.From(Environment))){0}[Data],
				    CompanyParam = Table.SelectRows(EnvironmentParam, each Text.Upper([Name]) = Text.Upper(Text.From(Company))){0}[Data],    
				    Advanced = #"CompanyParam"{[Name="Advanced"]}[Data],
				    #"wiise/powerBI/v1.0" = Advanced{[Name="wiise/powerBI/v1.0"]}[Data],
				    purchaseLines_table = #"wiise/powerBI/v1.0"{[Name="purchaseLines",Signature="table"]}[Data],
				    #"Added Custom" = Table.AddColumn(purchaseLines_table, "date", each if [documentType] = "Quote" then [documentDate]
				else if [documentType] = "Invoice" or [documentType] = "Order" then [postingDate]
				else null),
				    #"Changed Type" = Table.TransformColumnTypes(#"Added Custom",{{"date", type date}}),
				    #"Reordered Columns" = Table.ReorderColumns(#"Changed Type",{"id", "documentType", "documentNo", "type", "no", "description", "date", "quantityBase", "quantity", "amountIncludingVAT", "shortcutDimension1Code", "shortcutDimension2Code", "postingDate", "documentDate", "buyFromVendorNo", "buyFromVendorName", "auxiliaryIndex1", "ETag"}),
				    #"Sorted Rows" = Table.Sort(#"Reordered Columns",{{"date", Order.Descending}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Sorted Rows",#date(1, 1, 1),null,Replacer.ReplaceValue,{"date"})
				in
				    #"Replaced Value"
				```

