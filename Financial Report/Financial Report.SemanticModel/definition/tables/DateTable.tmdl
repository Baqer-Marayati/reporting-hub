table DateTable
	lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0201
	dataCategory: Time

	column Date
		dataType: dateTime
		isKey
		formatString: General Date
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0202
