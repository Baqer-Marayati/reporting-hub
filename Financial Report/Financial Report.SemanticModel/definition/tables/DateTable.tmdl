	column IsWeekend
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0212
		summarizeBy: none
		sourceColumn: IsWeekend

		annotation SummarizationSetBy = Automatic

	column IsPreviousMonthToDate
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a0213
		summarizeBy: none
		sourceColumn: IsPreviousMonthToDate

		annotation SummarizationSetBy = Automatic

	partition DateTable = calculated
		mode: import
		source =
				
				ADDCOLUMNS (
				    CALENDAR ( DATE ( YEAR ( TODAY () ) - 5, 1, 1 ), EOMONTH ( TODAY (), 5 ) ),
				    "Year", YEAR ( [Date] ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "Month", MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMMM" ),
				    "Month Name Short", FORMAT ( [Date], "MMM yy" ),
				    "MonthsortOrder", YEAR ( [Date] ) * 100 + MONTH ( [Date] ),
				    "Day", DAY ( [Date] ),
				    "Day Name", FORMAT ( [Date], "dddd" ),
				    "Weekday Number", WEEKDAY ( [Date], 2 ),
				    "IsWeekend", WEEKDAY ( [Date], 2 ) > 5,
				    "IsPreviousMonthToDate",
				        [Date] >= EOMONTH ( TODAY (), -2 ) + 1
				            && [Date] <= DATE ( YEAR ( EDATE ( TODAY (), -1 ) ), MONTH ( EDATE ( TODAY (), -1 ) ), DAY ( TODAY () ) )
				)

	annotation PBI_Id = 4f1c4f8e3cc34d189a8c3f2e189a0201
