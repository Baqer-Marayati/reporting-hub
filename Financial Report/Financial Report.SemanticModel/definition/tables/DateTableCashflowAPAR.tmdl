table DateTableCashflowAPAR
	lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a1121

	column Date
		dataType: dateTime
		formatString: General Date
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a1122
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

	column 'Month Year'
		dataType: string
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a1123
		summarizeBy: none
		sourceColumn: Month Year

		annotation SummarizationSetBy = Automatic

	column IsInLast6Months_PTO
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		lineageTag: 4f1c4f8e-3cc3-4d18-9a8c-3f2e189a1124
		summarizeBy: none
		sourceColumn: IsInLast6Months_PTO

		annotation SummarizationSetBy = Automatic

	partition DateTableCashflowAPAR = calculated
		mode: import
		source =
				
				SELECTCOLUMNS (
				    FILTER (
				        'DateTable',
				        'DateTable'[Date] >= DATE ( YEAR ( EDATE ( TODAY (), -5 ) ), MONTH ( EDATE ( TODAY (), -5 ) ), 1 )
				            && 'DateTable'[Date] <= EOMONTH ( TODAY (), 0 )
				    ),
				    "Date", 'DateTable'[Date],
				    "Month Year", 'DateTable'[Month Name Short],
				    "IsInLast6Months_PTO", TRUE ()
				)

	annotation PBI_Id = 4f1c4f8e3cc34d189a8c3f2e189a1121
