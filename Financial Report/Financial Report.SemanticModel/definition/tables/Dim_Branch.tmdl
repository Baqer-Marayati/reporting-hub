table Dim_Branch
	lineageTag: 795d7bff-82fc-494b-8606-8b04a1c57fd1

	column BranchCode
		lineageTag: 8a5d3dc9-492e-4b5d-8774-c963e79ef622
		summarizeBy: none
		isNameInferred
		sourceColumn: [BranchCode]

		annotation SummarizationSetBy = Automatic

	column BranchName
		lineageTag: e089c29e-f165-463b-bb20-a4f6e6f5994f
		summarizeBy: none
		isNameInferred
		sourceColumn: [BranchName]

		annotation SummarizationSetBy = Automatic

	partition Dim_Branch = calculated
		mode: import
		source =
				
				FILTER(
				    DISTINCT(
				        SELECTCOLUMNS(
				            'Fact_PNL',
				            "BranchCode", 'Fact_PNL'[BranchCode],
				            "BranchName", 'Fact_PNL'[BranchName]
				        )
				    ),
				    NOT ISBLANK([BranchCode])
				)

	annotation PBI_Id = a724b8f0866c4f548322fdc3f8449e5c

