		lineageTag: 7d4f2215-d88f-4f13-b1cc-f64aef7b6182

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Chart Row Var' =
			
			[Chart Row YTD] - [Chart Row YTD LY]
