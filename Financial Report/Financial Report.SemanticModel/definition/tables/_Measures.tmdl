			    SWITCH (
			        TRUE (),
			        RowType = "Header", BLANK (),
			        RowType = "Account", AccountValue,
			        SectionName = "Gross Revenue", CALCULATE ( [Gross Revenue], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Revenue Adjustments", CALCULATE ( [Revenue Adjustments], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Net Revenue", [Net Revenue YTD],
			        SectionName = "COGS", CALCULATE ( [COGS], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Gross Profit", [Gross Profit YTD],
			        SectionName = "Operating Expenses", CALCULATE ( [Operating Expenses], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Operating Profit", [Operating Profit YTD],
			        SectionName = "Other Income / Expense", CALCULATE ( [Other Income / Expense], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Tax & Extraordinary", CALCULATE ( [Tax & Extraordinary], DATESYTD ( 'Dim_Date'[Date] ) ),
			        SectionName = "Net Profit", [Net Profit YTD]
			    )
		formatString: #,0\ "د.ع.‏";-#,0\ "د.ع.‏";#,0\ "د.ع.‏"
		lineageTag: 0ab6dc5e-92fe-4ad9-afee-e2909e2097cb

		annotation PBI_FormatHint = {"currencyCulture":"ar-IQ"}

	measure 'Statement YTD LY' =
			
			VAR RowType = SELECTEDVALUE ( 'Dim_ReportRows'[RowType] )
			VAR SectionName = SELECTEDVALUE ( 'Dim_ReportRows'[SectionName] )
			VAR AcctCode = SELECTEDVALUE ( 'Dim_ReportRows'[AcctCode] )
			VAR AccountValue =
			    CALCULATE (
			        [Amount Display],
			        DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ),
			        TREATAS ( { AcctCode }, 'Fact_PNL'[AcctCode] )
