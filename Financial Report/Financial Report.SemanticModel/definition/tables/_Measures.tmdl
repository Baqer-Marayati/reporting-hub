			        SectionName = "Revenue Adjustments", CALCULATE ( [Revenue Adjustments], DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ) ),
			        SectionName = "Net Revenue", [Net Revenue YTD LY],
			        SectionName = "COGS", CALCULATE ( [COGS], DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ) ),
			        SectionName = "Gross Profit", [Gross Profit YTD LY],
			        SectionName = "Operating Expenses", CALCULATE ( [Operating Expenses], DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ) ),
			        SectionName = "Operating Profit", [Operating Profit YTD LY],
			        SectionName = "Other Income / Expense", CALCULATE ( [Other Income / Expense], DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ) ),
			        SectionName = "Tax & Extraordinary", CALCULATE ( [Tax & Extraordinary], DATEADD ( DATESYTD ( 'Dim_Date'[Date] ), -1, YEAR ) ),
			        SectionName = "Net Profit", [Net Profit YTD LY]
