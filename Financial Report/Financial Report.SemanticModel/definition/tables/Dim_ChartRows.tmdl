table Dim_ChartRows
	lineageTag: 2966c65b-2ee4-456c-aec6-f0c1b5c6612a

	column SortOrder
		dataType: int64
		formatString: 0
		lineageTag: ea74859e-ad78-4c9a-9948-c45f097314d7
		summarizeBy: none
		sourceColumn: SortOrder

		annotation SummarizationSetBy = Automatic

	column RowLabel
		dataType: string
		lineageTag: 41a4d787-a0dc-4fcf-9335-a39f0bf9a30e
		summarizeBy: none
		sourceColumn: RowLabel
		sortByColumn: SortOrder

		annotation SummarizationSetBy = Automatic

